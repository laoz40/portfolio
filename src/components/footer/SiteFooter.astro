---
import ObfuscatedEmailRuntime from "../contact/ObfuscatedEmailRuntime.astro";
import NavLink from "../navigation/NavLink.astro";
import { encodeEmailHref } from "../../utils/obfuscatedEmail";

type FooterLink = {
	label: string;
	href: string;
	variant: "lime";
	target: string | undefined;
	rel: string | undefined;
};

const contactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL;
const linkedInUrl = import.meta.env.PUBLIC_LINKEDIN_URL;
const encodedEmailHref = contactEmail
	? encodeEmailHref(contactEmail)
	: undefined;

const footerLinks = [
	linkedInUrl
		? {
				label: "LinkedIn",
				href: linkedInUrl,
				variant: "lime",
				target: "_blank",
				rel: "noreferrer",
			}
		: null,
].filter((link): link is FooterLink => link !== null);
---

<footer
	id="contact"
	aria-label="Social and contact links"
	class="mt-40 grid grid-cols-1 items-start justify-items-center gap-[0.85rem] pb-32"
	data-footer-root
	transition:animate="none">
	<ObfuscatedEmailRuntime />
	<div class="grid justify-items-center gap-[0.2rem] text-balance">
		<a
			class="footer-cta-link"
			href="/contact">
			If you've scrolled this far, you probably wanted these:
		</a>
	</div>

	<div class="footer-links flex flex-wrap items-center justify-center gap-2">
		{
			contactEmail ? (
				<NavLink
					href="#"
					variant="lime"
					data-email-link="true"
					data-email-entities={encodedEmailHref}>
					Email
				</NavLink>
			) : null
		}
		{
			footerLinks.map((link) => (
				<NavLink
					href={link.href}
					variant={link.variant}
					target={link.target}
					rel={link.rel}>
					{link.label}
				</NavLink>
			))
		}
	</div>

	<div class="flex w-full flex-col items-center justify-center gap-[0.2rem]">
		<p class="footer-copyright">
			<span aria-hidden="true">&copy;</span>
			<span data-current-year>0000</span>
			<span>Leo Zhou</span>
		</p>
		<p class="footer-note">
			Handwriting typeface created by me. Please don't steal my identity.
		</p>
	</div>
</footer>

<script is:inline>
	function syncFooterYear() {
		const currentYearTargets = document.querySelectorAll("[data-current-year]");

		if (currentYearTargets.length === 0) {
			return;
		}

		const currentYear = new Date().toLocaleDateString(undefined, {
			year: "numeric",
		});

		currentYearTargets.forEach((target) => {
			target.textContent = currentYear;
		});
	}

	function revealFooterOnceVisible(entries, observer, footerRoot) {
		for (const entry of entries) {
			if (!entry.isIntersecting) {
				continue;
			}

			footerRoot.classList.add("is-visible");
			observer.disconnect();
			return;
		}
	}

	function initFooterReveal() {
		const footerRoot = document.querySelector("[data-footer-root]");

		if (!(footerRoot instanceof HTMLElement)) {
			return;
		}

		if (footerRoot.dataset.animReady === "true") {
			return;
		}

		footerRoot.dataset.animReady = "true";

		if (!("IntersectionObserver" in window)) {
			footerRoot.classList.add("is-visible");
			return;
		}

		const observer = new IntersectionObserver(
			(entries) => revealFooterOnceVisible(entries, observer, footerRoot),
			{
				threshold: 0.25,
				rootMargin: "0px 0px -8% 0px",
			},
		);

		observer.observe(footerRoot);
	}

	function initFooterUi() {
		syncFooterYear();
		initFooterReveal();
	}

	initFooterUi();
	document.addEventListener("astro:page-load", initFooterUi);
</script>

<style>
	footer {
		display: grid;
		grid-template-columns: 1fr;
		align-items: start;
		justify-items: center;
		gap: 0.85rem;
		margin-top: 10rem;
		padding-bottom: 8rem;
		opacity: 0;
		transform: translateY(1rem);
		transition:
			opacity 420ms ease,
			transform 420ms cubic-bezier(0.2, 0.9, 0.2, 1);
	}

	footer.is-visible {
		opacity: 1;
		transform: translateY(0);
	}

	.footer-cta-link {
		font-family: var(--font-handwriting);
		color: var(--color-text-handwriting);
		font-size: var(--type-hand-size-title-lg);
		font-weight: 700;
		line-height: 1;
		text-align: center;
		text-decoration: none;
	}

	.footer-copyright {
		margin: 0;
		font-family: var(--font-handwriting);
		color: var(--color-text-muted);
	}

	.footer-note {
		margin: 1rem;
		font-family: var(--font-handwriting);
		font-weight: var(--type-hand-weight-regular);
		color: var(--color-text-muted);
		text-align: center;
		text-wrap: balance;
	}

	@media (max-width: 640px) {
		.footer-links :global(.nav-link-text) {
			font-size: 1.5rem;
		}
	}
</style>
