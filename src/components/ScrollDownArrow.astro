---
const { href = '#featured', label = 'Scroll to featured section' } = Astro.props;
---

<a class="scroll-down" href={href} aria-label={label}>
	<svg viewBox="0 0 56 56" aria-hidden="true" focusable="false">
		<path
			d="M28 8 C27 20, 27 30, 28 42"
			fill="none"
			stroke="currentColor"
			stroke-width="3.2"
			stroke-linecap="round"
		/>
		<path
			d="M18 34 C22 39, 25 43, 28 48"
			fill="none"
			stroke="currentColor"
			stroke-width="3.2"
			stroke-linecap="round"
		/>
		<path
			d="M38 34 C34 39, 31 43, 28 48"
			fill="none"
			stroke="currentColor"
			stroke-width="3.2"
			stroke-linecap="round"
		/>
	</svg>
</a>

<style>
	.scroll-down {
		position: absolute;
		bottom: 2rem;
		left: 50%;
		transform: translateX(-50%);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		line-height: 1;
		text-decoration: none;
		animation: bob 1.8s ease-in-out infinite;
	}

	.scroll-down svg {
		width: 3rem;
		height: 3rem;
		filter: drop-shadow(1px 2px 0 rgba(0, 0, 0, 0.15));
	}

	.scroll-down:hover {
		animation-play-state: paused;
		transform: translateX(-50%) translateY(0.25rem) rotate(-2deg);
	}

	@keyframes bob {
		0%,
		100% {
			transform: translateX(-50%) translateY(0);
		}

		50% {
			transform: translateX(-50%) translateY(0.35rem);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.scroll-down {
			animation: none;
		}

		.scroll-down:hover {
			transform: translateX(-50%);
		}
	}
</style>
