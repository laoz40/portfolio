<div
	class="relative flex min-h-svh w-full flex-col"
	style="background-color: var(--color-surface-page); color: var(--color-text-default);">
	<div
		class="pointer-events-none absolute inset-0 z-0"
		style={`background-image:
			linear-gradient(var(--color-grid-line) 1px, transparent 1px),
			linear-gradient(90deg, var(--color-grid-line) 1px, transparent 1px),
			linear-gradient(var(--color-grid-line-alt) 1px, transparent 1px),
			linear-gradient(90deg, var(--color-grid-line-alt) 1px, transparent 1px);
			background-size: 15px 15px, 15px 15px, 30px 30px, 30px 30px;
			background-position: 0 0, 0 0, 0 0, 0 0;`}>
	</div>
	<!-- Paper grain texture overlay -->
	<div
		class="pointer-events-none absolute inset-0 z-0 opacity-30 mix-blend-multiply">
		<svg class="grain-svg">
			<filter id="grain">
				<feTurbulence
					type="fractalNoise"
					baseFrequency="0.5"
					numOctaves="3"
					stitchTiles="stitch"
				></feTurbulence>
			</filter>
			<rect
				width="100%"
				height="100%"
				filter="url(#grain)"
			></rect>
		</svg>
	</div>
	<slot />
</div>

<style>
	.grain-svg {
		width: 100%;
		height: 100%;
	}
</style>
