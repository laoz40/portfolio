---
const { href, hlColour = "rgb(255 230 0 / 0.75)" } = Astro.props;
---
<a href={href} style={`--hl-colour: ${hlColour}`}>
	<div>
		<slot />
	</div>
</a>

<style>
	a {
		display: inline-block;
		text-decoration: none;
	}

	a > div {
		position: relative;
		display: inline-block;
		font-size: 1.75rem;
		line-height: 1.1;
		padding: 1.5rem 1rem;
		user-select: none;
		z-index: 0;
		transition: transform 120ms ease;
	}

	a > div::before {
		content: "";
		position: absolute;
		left: -0.18em;
		right: -0.16em;
		top: 0.4em;
		bottom: 0.5em;
		background: var(--hl-colour);
		clip-path: polygon(
			2% 22%,
			8% 8%,
			35% 5%,
			48% 14%,
			78% 18%,
			98% 24%,
			96% 82%,
			88% 95%,
			57% 94%,
			42% 86%,
			28% 93%,
			13% 85%,
			4% 91%
		);
		transform-origin: left;
		transform: scaleX(0.2) skewX(-4deg) rotate(-1.2deg);
		opacity: 0;
		transition: transform 220ms ease, opacity 100ms ease;
		z-index: -1;
		pointer-events: none;
	}

	a:hover > div::before,
	a:focus-visible > div::before {
		transform: scaleX(1) skewX(-4deg) rotate(-1.2deg);
		opacity: 1;
	}

	a:active > div {
		transform: scale(0.95);
	}
</style>
