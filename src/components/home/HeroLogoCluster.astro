---
import { Image } from "astro:assets";
import tsImage from "../../assets/home/ts.webp";
import reactImage from "../../assets/home/react.webp";
import nextjsImage from "../../assets/home/nextjs.webp";
import cssImage from "../../assets/home/css.webp";
import figmaImage from "../../assets/home/figma.webp";
---

<div
	class="hero-logo-cluster hero-image-reveal"
	aria-hidden="true">
	<p class="hero-logo-label">Stuff I use</p>
	<Image
		class="hero-logo hero-logo-ts"
		src={tsImage}
		alt=""
		loading="eager"
		fetchpriority="high"
		decoding="async"
	/>
	<Image
		class="hero-logo hero-logo-react"
		src={reactImage}
		alt=""
		loading="eager"
		fetchpriority="high"
		decoding="async"
	/>
	<Image
		class="hero-logo hero-logo-nextjs"
		src={nextjsImage}
		alt=""
		loading="eager"
		fetchpriority="high"
		decoding="async"
	/>
	<Image
		class="hero-logo hero-logo-css"
		src={cssImage}
		alt=""
		loading="eager"
		fetchpriority="high"
		decoding="async"
	/>
	<Image
		class="hero-logo hero-logo-figma"
		src={figmaImage}
		alt=""
		loading="eager"
		fetchpriority="high"
		decoding="async"
	/>
</div>

<style>
	.hero-logo-cluster {
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
		user-select: none;
	}

	.hero-logo {
		position: absolute;
		right: 2rem;
		width: 6.5rem;
		height: auto;
		object-fit: contain;
		opacity: 0.8;
		filter: saturate(0.5) contrast(1.1);
	}

	.hero-logo-label {
		position: absolute;
		right: 1.75rem;
		top: 8.5rem;
		margin: 0;
		font-family: var(--font-handwriting);
		font-size: var(--type-hand-size-note);
		letter-spacing: 0.01em;
		color: var(--color-text-muted);
		transform: rotate(-1deg);
		opacity: 0.78;
	}

	.hero-logo-ts {
		top: 11rem;
		right: 7rem;
		transform: rotate(6deg);
	}

	.hero-logo-react {
		top: 25rem;
		right: 8rem;
		transform: rotate(-8deg);
	}

	.hero-logo-nextjs {
		top: 19.5rem;
		right: 0;
		width: 7rem;
		transform: rotate(5deg);
	}

	.hero-logo-css {
		top: 31rem;
		right: 1.5rem;
		transform: rotate(-6deg);
	}

	.hero-logo-figma {
		top: 39.5rem;
		right: 1rem;
		width: 5.75rem;
		transform: rotate(8deg);
	}

	@media (max-width: 980px) {
		.hero-logo {
			right: 1rem;
			width: 5rem;
		}

		.hero-logo-ts {
			top: 9.25rem;
			right: 5rem;
		}

		.hero-logo-react {
			top: 17.75rem;
			right: 6.25rem;
		}

		.hero-logo-nextjs {
			top: 15.5rem;
			right: 0.75rem;
			width: 5.5rem;
		}

		.hero-logo-css {
			top: 24.75rem;
			right: 1.25rem;
		}

		.hero-logo-figma {
			top: 32rem;
			right: 1rem;
			width: 4.75rem;
		}
		.hero-logo-label {
			top: 5.75rem;
			right: 1rem;
			font-size: var(--type-hand-size-label-sm);
		}
	}

	@media (max-width: 820px) {
		.hero-logo-label,
		.hero-logo-ts,
		.hero-logo-css {
			display: none;
		}

		.hero-logo {
			width: 4rem;
			right: 0.75rem;
			opacity: 0.75;
		}

		.hero-logo-react {
			top: 12rem;
			right: 4.25rem;
			width: 4.1rem;
		}

		.hero-logo-nextjs {
			top: 8rem;
			right: 0.5rem;
			width: 4.4rem;
		}

		.hero-logo-figma {
			top: 20rem;
			right: 0.85rem;
			width: 3.8rem;
		}
	}

	@media (max-width: 640px) {
		.hero-logo-cluster {
			display: block;
		}

		.hero-logo-label,
		.hero-logo-ts,
		.hero-logo-css {
			display: none;
		}

		.hero-logo {
			width: 3.2rem;
			opacity: 0.75;
		}

		.hero-logo-react {
			top: 8.75rem;
			right: 3rem;
			width: 3.35rem;
		}

		.hero-logo-nextjs {
			top: 4.5rem;
			right: 0.85rem;
			width: 3.5rem;
		}

		.hero-logo-figma {
			top: 13.75rem;
			right: 1.1rem;
			width: 3rem;
		}
	}
</style>
