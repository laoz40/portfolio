---
import { Image } from "astro:assets";
import dolphinImage from "../../assets/home/dolphin.webp";
import icecreamImage from "../../assets/home/icecream.webp";
import meImage from "../../assets/home/me.webp";
import penroseImage from "../../assets/home/penrose.webp";
---

<div class="hero-art-cluster">
	<Image
		class="hero-portrait"
		src={meImage}
		alt="Illustration of Leo"
		loading="eager"
		fetchpriority="high"
		decoding="async"
	/>

	<div
		class="hero-sketch-cluster"
		aria-hidden="true">
		<Image
			class="hero-sketch hero-sketch-dolphin"
			src={dolphinImage}
			alt=""
			loading="eager"
			fetchpriority="high"
			decoding="async"
		/>
		<Image
			class="hero-sketch hero-sketch-icecream"
			src={icecreamImage}
			alt=""
			loading="eager"
			fetchpriority="high"
			decoding="async"
		/>
		<Image
			class="hero-sketch hero-sketch-penrose"
			src={penroseImage}
			alt=""
			loading="eager"
			fetchpriority="high"
			decoding="async"
		/>
	</div>
</div>

<style>
	.hero-art-cluster {
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
		user-select: none;
	}

	.hero-portrait {
		position: absolute;
		left: 0;
		top: 6vh;
		z-index: 1;
		width: 18rem;
		max-height: min(52svh, 32rem);
		object-fit: contain;
		object-position: bottom left;
		opacity: 0.9;
	}

	.hero-sketch-cluster {
		position: absolute;
		inset: 0;
		z-index: 0;
	}

	.hero-sketch {
		position: absolute;
		width: 6.5rem;
		height: auto;
		object-fit: contain;
		opacity: 0.7;
		filter: drop-shadow(0 0.35rem 0.45rem rgb(54 43 21 / 0.12));
	}

	.hero-sketch-dolphin {
		left: 0.5rem;
		top: 36rem;
		width: 7.5rem;
		transform: rotate(-9deg);
	}

	.hero-sketch-icecream {
		left: 12rem;
		top: 36rem;
		transform: rotate(7deg);
	}

	.hero-sketch-penrose {
		left: 5rem;
		top: 48rem;
		width: 5.5rem;
		transform: rotate(12deg);
	}

	@media (max-width: 980px) {
		.hero-portrait {
			width: 15rem;
			max-height: min(46svh, 28rem);
		}

		.hero-sketch {
			width: 4.75rem;
		}

		.hero-sketch-dolphin {
			left: 0.25rem;
			top: 24rem;
			width: 5.5rem;
		}

		.hero-sketch-icecream {
			left: 5.5rem;
			top: 24.5rem;
		}

		.hero-sketch-penrose {
			left: 3rem;
			top: 35rem;
			width: 4rem;
		}
	}

	@media (max-width: 820px) {
		.hero-portrait {
			left: max(0.25rem, env(safe-area-inset-left));
			top: 4.75rem;
			width: 12rem;
			max-height: 32svh;
		}

		.hero-sketch-dolphin {
			left: 0.75rem;
			top: 25rem;
			width: 4.75rem;
		}

		.hero-sketch-icecream {
			left: 6rem;
			top: 24.5rem;
			width: 4.25rem;
		}

		.hero-sketch-penrose {
			display: none;
		}
	}

	@media (max-width: 640px) {
		.hero-portrait {
			left: max(0.25rem, env(safe-area-inset-left));
			top: 4.5rem;
			width: 10rem;
			max-height: 28svh;
			opacity: 0.9;
		}

		.hero-sketch-cluster {
			display: none;
		}
	}
</style>
