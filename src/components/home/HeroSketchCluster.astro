---
import dolphinImage from "../../assets/home/dolphin.webp";
import icecreamImage from "../../assets/home/icecream.webp";
import meImage from "../../assets/home/me.webp";
import penroseImage from "../../assets/home/penrose.webp";
---

<div class="hero-art-cluster">
	<img
		class="hero-portrait"
		src={meImage.src}
		alt="Illustration of Leo"
		decoding="async"
	/>

	<div
		class="hero-sketch-cluster"
		aria-hidden="true">
		<img
			class="hero-sketch hero-sketch-dolphin"
			src={dolphinImage.src}
			alt=""
			decoding="async"
		/>
		<img
			class="hero-sketch hero-sketch-icecream"
			src={icecreamImage.src}
			alt=""
			decoding="async"
		/>
		<img
			class="hero-sketch hero-sketch-penrose"
			src={penroseImage.src}
			alt=""
			decoding="async"
		/>
	</div>
</div>

<style>
	.hero-art-cluster {
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
		user-select: none;
	}

	.hero-portrait {
		position: absolute;
		left: 0;
		top: 10vh;
		z-index: 1;
		width: clamp(12rem, 24vw, 22rem);
		max-height: min(52svh, 32rem);
		object-fit: contain;
		object-position: bottom left;
	}

	.hero-sketch-cluster {
		position: absolute;
		inset: 0;
		z-index: 0;
	}

	.hero-sketch {
		position: absolute;
		width: clamp(4.5rem, 9vw, 8.5rem);
		height: auto;
		object-fit: contain;
		opacity: 0.95;
		filter: drop-shadow(0 0.35rem 0.45rem rgb(54 43 21 / 0.12));
	}

	.hero-sketch-dolphin {
		left: clamp(-0.5rem, 1vw, 1rem);
		top: clamp(33rem, 60vh, 39rem);
		width: clamp(5.5rem, 11vw, 9.5rem);
		transform: rotate(-9deg);
	}

	.hero-sketch-icecream {
		left: clamp(8.5rem, 15vw, 15rem);
		top: clamp(33rem, 60vh, 39rem);
		transform: rotate(7deg);
	}

	.hero-sketch-penrose {
		left: clamp(3rem, 7vw, 6.5rem);
		top: clamp(45rem, 79vh, 51rem);
		width: clamp(4rem, 8vw, 7rem);
		transform: rotate(12deg);
	}

	@media (max-width: 980px) {
		.hero-sketch {
			width: clamp(3.25rem, 8vw, 6rem);
		}

		.hero-sketch-dolphin {
			left: clamp(-0.5rem, 0vw, 0.75rem);
			top: clamp(29rem, 55vh, 33rem);
			width: clamp(4rem, 9vw, 6.5rem);
		}

		.hero-sketch-icecream {
			left: clamp(4rem, 9vw, 7rem);
			top: clamp(29rem, 54vh, 33rem);
		}

		.hero-sketch-penrose {
			left: clamp(2rem, 5vw, 3.75rem);
			top: clamp(38.5rem, 71vh, 42rem);
			width: clamp(3rem, 6.5vw, 5rem);
		}
	}

	@media (max-width: 640px) {
		.hero-portrait {
			left: max(0.25rem, env(safe-area-inset-left));
			width: clamp(8rem, 30vw, 12rem);
			max-height: 28svh;
			opacity: 0.9;
		}

		.hero-sketch-cluster {
			display: none;
		}
	}
</style>
