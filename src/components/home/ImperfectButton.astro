---
const buttonPath = `M14,11
	C24,11 14,11 84,9
	C120,11 158,8 188,10
	C198,10 200,10 200,21
	L201,43
	C199,58 198,58 191,60
	C159,58 123,63 91,61
	C57,62 28,64 17,61
	C-1,60 7,60 5,38
	L6,23
	C7,17 5,13 14,11 Z`;
const { fill, href, target, rel, ...attributes } = Astro.props as {
	fill: string;
	href?: string;
	target?: string;
	rel?: string;
	[key: string]: unknown;
};
---

{
	href ? (
		<a
			href={href}
			target={target}
			rel={rel}
			{...attributes}
			class="imperfect-button"
			style={`--fill: ${fill};`}>
			<span>
				<slot />
			</span>

			<svg
				viewBox="0 0 220 70"
				preserveAspectRatio="none"
				aria-hidden="true">
				<path
					d={buttonPath}
					transform="translate(10 0)"
					stroke="none"
					stroke-width="3"
					stroke-linecap="round"
					stroke-linejoin="round"
				/>
			</svg>
		</a>
	) : (
		<button
			type="button"
			{...attributes}
			class="imperfect-button"
			style={`--fill: ${fill};`}>
			<span>
				<slot />
			</span>

			<svg
				viewBox="0 0 220 70"
				preserveAspectRatio="none"
				aria-hidden="true">
				<path
					d={buttonPath}
					transform="translate(10 0)"
					stroke="none"
					stroke-width="3"
					stroke-linecap="round"
					stroke-linejoin="round"
				/>
			</svg>
		</button>
	)
}

<style>
	.imperfect-button {
		position: relative;
		display: inline-grid;
		place-items: center;
		--fill-solid: rgb(from var(--fill) r g b);
		--paper-fill: var(--fill-solid);
		--button-shadow-rest: 3px 4px 2px rgb(0 0 0 / 0.14);
		--button-shadow-hover: 5px 6px 3px rgb(0 0 0 / 0.2);
		--button-motion-duration: 0.16s;
		--button-motion-easing: cubic-bezier(0.22, 1, 0.36, 1);
		--button-motion-active-duration: 0.08s;
		--button-motion-active-easing: cubic-bezier(0.3, 0, 0.4, 1);
		padding: clamp(0.75rem, 1.8vw, 1rem) clamp(1.2rem, 3.5vw, 2rem);
		border: 0;
		cursor: pointer;
		user-select: none;
		font-size: clamp(1.1rem, 3.7vw, 2rem);
		font-weight: 700;
		text-decoration: none;
		transition: transform var(--button-motion-duration)
			var(--button-motion-easing);
	}

	span {
		position: relative;
		z-index: 1000;
		letter-spacing: 0.2px;
		user-select: none;
	}

	svg {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		pointer-events: none;
		transition:
			transform var(--button-motion-duration) var(--button-motion-easing),
			filter var(--button-motion-duration) var(--button-motion-easing),
			fill var(--button-motion-duration) var(--button-motion-easing);
		filter: drop-shadow(var(--button-shadow-rest));
		fill: var(--paper-fill);
	}

	path {
		stroke-width: 3.2;
	}

	.imperfect-button:hover {
		transform: translate(-2px, -3px) rotate(-0.9deg);
	}

	.imperfect-button:hover svg {
		filter: drop-shadow(var(--button-shadow-hover));
	}

	.imperfect-button:active {
		transition-duration: var(--button-motion-active-duration);
		transition-timing-function: var(--button-motion-active-easing);
		transform: translate(1px, 1px) rotate(-0.15deg);
	}

	.imperfect-button:active svg {
		transition-duration: var(--button-motion-active-duration);
		transition-timing-function: var(--button-motion-active-easing);
		filter: drop-shadow(2px 3px 2px rgb(0 0 0 / 0.18));
	}

	@media (prefers-reduced-motion: reduce) {
		.imperfect-button,
		svg {
			transition: none;
		}

		.imperfect-button:hover,
		.imperfect-button:active {
			transform: none;
		}
	}
</style>
