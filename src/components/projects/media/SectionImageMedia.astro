---
import type { ImageMetadata } from "astro";

const { image, alt } = Astro.props as {
	image: ImageMetadata;
	alt?: string;
};
---

<div class="section-media">
	<img
		class="section-media-image"
		src={image.src}
		alt={alt ?? ""}
		width={image.width}
		height={image.height}
		loading="lazy"
		decoding="async"
	/>
</div>

<style>
	.section-media {
		position: relative;
		width: 100%;
		align-self: center;
		min-height: clamp(12rem, 36vh, 22rem);
		background: var(--color-accent-lime);
		border: 8px solid var(--color-surface-paper);
		box-shadow: var(--shadow-paper-rest);
		transform: rotate(var(--section-media-tilt, 0deg));
		overflow: hidden;
	}

	.section-media::before {
		content: "";
		position: absolute;
		top: 0;
		left: 50%;
		width: var(--size-project-tape-width);
		height: var(--size-project-tape-height);
		transform: translate(-50%, -50%) rotate(1.2deg);
		background: var(--color-tape);
		pointer-events: none;
		z-index: 1;
	}

	.section-media-image {
		display: block;
		width: 100%;
		height: 100%;
		min-height: inherit;
		object-fit: cover;
	}

	@media (max-width: 1240px) {
		.section-media {
			min-height: clamp(10rem, 45vw, 14rem);
			width: min(100%, 42rem);
		}
	}

	@media (max-width: 640px) {
		.section-media {
			min-height: 9rem;
		}
	}
</style>
