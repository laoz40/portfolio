---
import type { ImageMetadata } from "astro";

const { image, alt } = Astro.props as {
	image: ImageMetadata;
	alt?: string;
};
---

<div
	class="section-media-frame"
	style={`--section-media-max-width: ${image.width}px; --section-media-aspect-ratio: ${image.width} / ${image.height};`}>
	<div class="section-media">
		<img
			class="section-media-image"
			src={image.src}
			alt={alt ?? ""}
			width={image.width}
			height={image.height}
			loading="lazy"
			decoding="async"
		/>
	</div>
</div>

<style>
	.section-media-frame {
		position: relative;
		width: min(100%, var(--section-media-max-width));
		align-self: center;
		padding-top: calc(var(--size-project-tape-height) * 0.5);
		min-width: 0;
	}

	.section-media-frame::before {
		content: "";
		position: absolute;
		top: calc(var(--size-project-tape-height) * 0.5);
		left: 50%;
		width: var(--size-project-tape-width);
		height: var(--size-project-tape-height);
		transform: translate(-50%, -50%)
			rotate(calc(var(--section-media-tilt, 0deg) + 1.2deg));
		background: var(--color-tape);
		pointer-events: none;
		z-index: 2;
	}

	.section-media {
		position: relative;
		aspect-ratio: var(--section-media-aspect-ratio);
		background: var(--color-media-fallback);
		border: 8px solid var(--color-surface-page);
		box-shadow: var(--shadow-paper-medium);
		transform: rotate(var(--section-media-tilt, 0deg));
		overflow: hidden;
		min-width: 0;
	}

	.section-media-image {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	@media (max-width: 1240px) {
		.section-media-frame {
			width: min(100%, 42rem, var(--section-media-max-width));
		}
	}

	@media (max-width: 640px) {
		.section-media {
			transform: none;
		}

		.section-media-frame::before {
			transform: translate(-50%, -50%) rotate(1.2deg);
		}
	}
</style>
