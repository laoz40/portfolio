---
import type { ImageMetadata } from "astro";

const { image, alt } = Astro.props as {
	image: ImageMetadata;
	alt?: string;
};
---

<div
	class="section-media"
	style={`--section-media-max-width: ${image.width}px; --section-media-aspect-ratio: ${image.width} / ${image.height};`}>
	<img
		class="section-media-image"
		src={image.src}
		alt={alt ?? ""}
		width={image.width}
		height={image.height}
		loading="lazy"
		decoding="async"
	/>
</div>

<style>
	.section-media {
		position: relative;
		width: min(100%, var(--section-media-max-width));
		align-self: center;
		aspect-ratio: var(--section-media-aspect-ratio);
		background: var(--color-accent-lime);
		border: 8px solid var(--color-surface-paper);
		box-shadow: var(--shadow-paper-rest);
		transform: rotate(var(--section-media-tilt, 0deg));
		overflow: hidden;
	}

	.section-media::before {
		content: "";
		position: absolute;
		top: 0;
		left: 50%;
		width: var(--size-project-tape-width);
		height: var(--size-project-tape-height);
		transform: translate(-50%, -50%) rotate(1.2deg);
		background: var(--color-tape);
		pointer-events: none;
		z-index: 1;
	}

	.section-media-image {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	@media (max-width: 1240px) {
		.section-media {
			width: min(100%, 42rem, var(--section-media-max-width));
		}
	}
</style>
