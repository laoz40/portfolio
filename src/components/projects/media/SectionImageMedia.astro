---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

const { image, alt } = Astro.props as {
	image: ImageMetadata;
	alt?: string;
};
---

<div
	class="section-media-frame taped-frame w-full min-w-0 self-center pt-[calc(var(--size-project-tape-height)*0.5)]"
	style={`--section-media-max-width: ${image.width}px; --section-media-aspect-ratio: ${image.width} / ${image.height}; --tape-angle: calc(var(--section-media-tilt, 0deg) + 1.2deg);`}>
	<div class="section-media paper-frame">
		<Image
			class="section-media-image"
			src={image}
			alt={alt ?? ""}
			width={image.width}
			height={image.height}
			loading="lazy"
			decoding="async"
		/>
	</div>
</div>

<style>
	.section-media-frame {
		width: min(100%, var(--section-media-max-width));
	}

	@media (min-width: 1450.02px) {
		.section-media-frame {
			width: min(
				var(--section-media-visual-max-width, var(--section-media-max-width)),
				max(
					100%,
					var(--section-media-visual-max-width, var(--section-media-max-width))
				)
			);
			justify-self: start;
		}
	}

	.section-media {
		position: relative;
		aspect-ratio: var(--section-media-aspect-ratio);
		transform: rotate(var(--section-media-tilt, 0deg));
		overflow: hidden;
		min-width: 0;
	}

	.section-media-image {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	@media (max-width: 1450px) {
		.section-media-frame {
			width: 100%;
		}
	}

	@media (max-width: 640px) {
		.section-media {
			transform: none;
		}

		.section-media-frame::before {
			transform: translate(-50%, -50%) rotate(1.2deg);
		}
	}
</style>
