---
const { videoId, title = "YouTube video" } = Astro.props as {
	videoId: string;
	title?: string;
};

const embedUrl = `https://www.youtube.com/embed/${videoId}`;
---

<div class="section-media-frame">
	<div class="section-media section-media--embed">
		<iframe
			class="section-media-embed"
			src={embedUrl}
			title={title}
			loading="lazy"
			allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
			referrerpolicy="strict-origin-when-cross-origin"
			allowfullscreen
		></iframe>
	</div>
</div>

<style>
	.section-media-frame {
		position: relative;
		width: 100%;
		align-self: center;
		padding-top: calc(var(--size-project-tape-height) * 0.5);
		min-width: 0;
	}

	.section-media-frame::before {
		content: "";
		position: absolute;
		top: calc(var(--size-project-tape-height) * 0.5);
		left: 50%;
		width: var(--size-project-tape-width);
		height: var(--size-project-tape-height);
		transform: translate(-50%, -50%)
			rotate(calc(var(--section-media-tilt, 0deg) + 1.2deg));
		background: var(--color-tape);
		pointer-events: none;
		z-index: 2;
	}

	.section-media {
		position: relative;
		min-height: clamp(12rem, 36vh, 22rem);
		background: var(--color-media-fallback);
		border: 8px solid var(--color-surface-page);
		box-shadow: var(--shadow-paper-medium);
		transform: rotate(var(--section-media-tilt, 0deg));
		min-width: 0;
	}

	.section-media--embed {
		aspect-ratio: 16 / 9;
		min-height: 0;
		overflow: hidden;
		transform: none;
	}

	.section-media-embed {
		display: block;
		width: 100%;
		height: 100%;
		border: 0;
	}

	@media (max-width: 1700px) {
		.section-media-frame {
			min-height: clamp(10rem, 45vw, 14rem);
			width: min(100%, 42rem);
		}

		.section-media--embed {
			min-height: 0;
		}
	}

	@media (max-width: 640px) {
		.section-media-frame {
			min-height: 9rem;
		}

		.section-media--embed {
			min-height: 0;
		}
	}
</style>
