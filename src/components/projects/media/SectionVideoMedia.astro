---
const { videoId, title = "YouTube video" } = Astro.props as {
	videoId: string;
	title?: string;
};

const embedUrl = `https://www.youtube.com/embed/${videoId}`;
---

<div class="section-media section-media--embed">
	<iframe
		class="section-media-embed"
		src={embedUrl}
		title={title}
		loading="lazy"
		allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
		referrerpolicy="strict-origin-when-cross-origin"
		allowfullscreen
	></iframe>
</div>

<style>
	.section-media {
		position: relative;
		width: 100%;
		align-self: center;
		min-height: clamp(12rem, 36vh, 22rem);
		background: var(--color-accent-lime);
		border: 8px solid var(--color-surface-page);
		box-shadow: var(--shadow-paper-medium);
		transform: rotate(var(--section-media-tilt, 0deg));
	}

	.section-media::before {
		content: "";
		position: absolute;
		top: 0;
		left: 50%;
		width: var(--size-project-tape-width);
		height: var(--size-project-tape-height);
		transform: translate(-50%, -50%) rotate(1.2deg);
		background: var(--color-tape);
		pointer-events: none;
		z-index: 2;
	}

	.section-media--embed {
		aspect-ratio: 16 / 9;
		min-height: 0;
		overflow: hidden;
		transform: none;
	}

	.section-media-embed {
		display: block;
		width: 100%;
		height: 100%;
		border: 0;
	}

	@media (max-width: 1240px) {
		.section-media {
			min-height: clamp(10rem, 45vw, 14rem);
			width: min(100%, 42rem);
		}

		.section-media--embed {
			min-height: 0;
		}
	}

	@media (max-width: 640px) {
		.section-media {
			min-height: 9rem;
		}

		.section-media--embed {
			min-height: 0;
		}
	}
</style>
