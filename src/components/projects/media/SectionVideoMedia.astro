---
const { videoId, title = "YouTube video" } = Astro.props as {
	videoId: string;
	title?: string;
};

const embedUrl = `https://www.youtube.com/embed/${videoId}`;
---

<div class="section-media section-media--embed">
	<iframe
		class="section-media-embed"
		src={embedUrl}
		title={title}
		loading="lazy"
		allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
		referrerpolicy="strict-origin-when-cross-origin"
		allowfullscreen
	></iframe>
</div>

<style>
	.section-media {
		position: sticky;
		top: clamp(8rem, 22vh, 12.5rem);
		width: 100%;
		min-height: clamp(12rem, 36vh, 22rem);
		background: var(--color-accent-lime);
		border: 8px solid var(--color-surface-paper);
		box-shadow: 0.5rem 0.5rem 1.5rem var(--color-shadow-ink-strong);
		transform: rotate(var(--section-media-tilt, 0deg));
	}

	.section-media--embed {
		aspect-ratio: 16 / 10;
		min-height: 0;
		overflow: hidden;
		transform: none;
	}

	.section-media-embed {
		display: block;
		width: 100%;
		height: 100%;
		border: 0;
	}

	@media (max-width: 1240px) {
		.section-media {
			position: static;
			min-height: clamp(10rem, 45vw, 14rem);
			width: min(100%, 42rem);
		}

		.section-media--embed {
			min-height: 0;
		}
	}

	@media (max-width: 640px) {
		.section-media {
			min-height: 9rem;
		}

		.section-media--embed {
			min-height: 0;
		}
	}
</style>
