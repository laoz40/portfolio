---
import type { CaseStudySection, SectionMedia } from "./caseStudySections";
import ScrollSpySidebar from "./ScrollSpySidebar.astro";
import SectionCarouselMedia from "./media/SectionCarouselMedia.astro";
import SectionImageMedia from "./media/SectionImageMedia.astro";
import SectionLinkButtons from "./SectionLinkButtons.astro";
import SectionPlaceholderMedia from "./media/SectionPlaceholderMedia.astro";
import SectionVideoMedia from "./media/SectionVideoMedia.astro";

const getYouTubeVideoId = (url: string) => {
	try {
		const parsedUrl = new URL(url);
		const shortCode =
			parsedUrl.hostname === "youtu.be"
				? parsedUrl.pathname.slice(1)
				: undefined;

		if (shortCode) {
			return shortCode;
		}

		const embedCode = parsedUrl.pathname.match(/^\/embed\/([^/?#]+)/)?.[1];

		if (embedCode) {
			return embedCode;
		}

		return parsedUrl.searchParams.get("v") ?? undefined;
	} catch {
		return undefined;
	}
};

const resolveSectionMedia = (
	explicitMedia?: SectionMedia,
	frontmatterMedia?: SectionMedia,
) => {
	const media = explicitMedia ?? frontmatterMedia;

	if (!media) {
		return undefined;
	}

	if (media.type === "youtube") {
		const videoId =
			media.videoId ?? (media.url ? getYouTubeVideoId(media.url) : undefined);

		if (!videoId) {
			return undefined;
		}

		return {
			...media,
			videoId,
		};
	}

	return media;
};

const resolveCarouselItems = (
	explicitItems?: CaseStudySection["carouselItems"],
	resolvedMedia?: SectionMedia,
): NonNullable<CaseStudySection["carouselItems"]> => {
	if (explicitItems && explicitItems.length > 0) {
		return explicitItems;
	}

	if (resolvedMedia?.type === "carousel" && resolvedMedia.items.length > 0) {
		return resolvedMedia.items;
	}

	return [];
};

type SectionLinks = Array<{
	label: string;
	href: string;
	fill: string;
}>;

type InlineGallery = {
	id: string;
	items: Array<{
		image: {
			src: string;
			width: number;
			height: number;
		};
		alt: string;
		caption?: string;
	}>;
};

const { sections, headingSelector = "h2" } = Astro.props as {
	sections: CaseStudySection[];
	headingSelector?: string;
};
---

<div class="project-shell mt-4">
	<ScrollSpySidebar headingSelector={headingSelector} />
	<article
		class="project-content flex flex-col gap-12"
		data-scrollspy-root>
		{
			sections.map((section) => {
				const SectionComponent = section.Component;
				const frontmatterSection = section.frontmatter?.section;
				const variant =
					section.variant ?? frontmatterSection?.variant ?? "contentOnly";
				const resolvedMedia = resolveSectionMedia(
					section.media,
					frontmatterSection?.media,
				);
				const isCarousel = variant === "carousel";
				const isContentOnly = variant === "contentOnly";
				const videoMedia =
					resolvedMedia?.type === "youtube" ? resolvedMedia : undefined;
				const imageMedia =
					resolvedMedia?.type === "image" ? resolvedMedia : undefined;
				const sectionProps = section.props ?? {};
				const carouselItems = resolveCarouselItems(
					section.carouselItems,
					resolvedMedia,
				);
				const sectionLinks =
					(frontmatterSection as { links?: SectionLinks } | undefined)?.links ??
					[];
				const inlineGalleries =
					(
						section.frontmatter as
							| { inlineGalleries?: InlineGallery[] }
							| undefined
					)?.inlineGalleries ?? [];
				const linksAriaLabel = (
					frontmatterSection as { ariaLabel?: string } | undefined
				)?.ariaLabel;

				return (
					<section
						class:list={[
							"section",
							`section--${variant}`,
							section.extraClass ?? frontmatterSection?.extraClass,
						]}>
						<div class="section-copy">
							<SectionComponent {...sectionProps} />
							{inlineGalleries.map((gallery) => (
								<template data-inline-gallery-template={gallery.id}>
									<div class="inline-gallery">
										{gallery.items.map((item) => (
											<div class="inline-gallery__frame">
												<figure class="inline-gallery__tile">
													<img
														class="inline-gallery__image"
														src={item.image.src}
														alt={item.alt}
														width={item.image.width}
														height={item.image.height}
														loading="lazy"
														decoding="async"
													/>
													{item.caption ? (
														<figcaption class="inline-gallery__caption">
															{item.caption}
														</figcaption>
													) : null}
												</figure>
											</div>
										))}
									</div>
								</template>
							))}
							{sectionLinks.length > 0 ? (
								<SectionLinkButtons
									links={sectionLinks}
									ariaLabel={linksAriaLabel}
								/>
							) : null}
						</div>
						{isContentOnly ? null : isCarousel ? (
							<SectionCarouselMedia items={carouselItems} />
						) : videoMedia ? (
							<SectionVideoMedia
								videoId={videoMedia.videoId}
								title={videoMedia.title}
							/>
						) : imageMedia ? (
							<SectionImageMedia
								image={imageMedia.image}
								alt={imageMedia.alt}
							/>
						) : (
							<SectionPlaceholderMedia />
						)}
					</section>
				);
			})
		}
	</article>
</div>

<script is:inline>
	const initInlineGalleries = () => {
		const placeholders = document.querySelectorAll(
			".inline-gallery[data-gallery]",
		);

		for (const placeholder of placeholders) {
			if (!(placeholder instanceof HTMLElement)) {
				continue;
			}

			const galleryId = placeholder.dataset.gallery;

			if (!galleryId || placeholder.dataset.inlineGalleryReady === "true") {
				continue;
			}

			const template = document.querySelector(
				`template[data-inline-gallery-template="${galleryId}"]`,
			);

			if (!(template instanceof HTMLTemplateElement)) {
				continue;
			}

			placeholder.replaceWith(template.content.cloneNode(true));
		}
	};

	initInlineGalleries();
	document.addEventListener("astro:page-load", initInlineGalleries);
</script>

<style>
	.project-shell {
		display: grid;
		grid-template-columns: clamp(10.5rem, 16vw, 14rem) minmax(0, 1fr);
		gap: clamp(1.5rem, 4vw, 5rem);
		align-items: start;
		width: 100%;
		margin-inline: auto;
	}

	.section {
		display: grid;
		grid-template-columns: minmax(0, 1fr) clamp(20rem, 34vw, 30rem);
		gap: clamp(1.25rem, 3vw, 2.5rem);
		align-items: start;
		min-width: 0;
	}

	.section-copy {
		min-width: 0;
	}

	.section:nth-of-type(odd) {
		--section-media-tilt: -0.4deg;
	}

	.section:nth-of-type(even) {
		--section-media-tilt: 0.4deg;
	}

	.section--contentOnly {
		grid-template-columns: 1fr;
	}

	.section--featured :global(.section-media-frame) {
		grid-column: 1 / -1;
	}

	.section--featured :global(.section-media--embed) {
		min-height: 0;
	}

	.section--carousel :global(.section-carousel) {
		position: static;
		grid-column: 1 / -1;
	}

	.section--carousel :global(.section-carousel-slide) {
		min-height: 0;
	}

	.project-content {
		--text-measure: 65ch;
		width: 100%;
		margin-inline: 0;
		padding-inline: clamp(0.25rem, 1.5vw, 1rem);
	}

	.project-content :global(h2) {
		scroll-margin-top: calc(var(--nav-offset) + 1rem);
	}

	.project-content :global(h1) {
		font-family: var(--font-handwriting);
		font-size: clamp(2.25rem, 9vw, 5rem);
		font-weight: 700;
		line-height: 0.95;
		margin: 0 0 1rem 0;
		max-width: 12ch;
	}

	.project-content :global(h2) {
		font-family: var(--font-handwriting);
		font-size: clamp(1.5rem, 3vw, 2.5rem);
		font-weight: 400;
		color: var(--color-text-body);
		letter-spacing: 0.01em;
		line-height: 1;
		margin: 2rem 0 1rem 0;
		max-width: 18ch;
	}

	.project-content :global(h3) {
		font-family: var(--font-handwriting);
		font-size: clamp(2.4rem, 3.2vw, 3.6rem);
		font-weight: 700;
		line-height: 0.95;
		max-width: 32ch;
		text-wrap: balance;
	}

	.project-content :global(h4) {
		font-family: var(--font-sans);
		font-size: var(--type-sans-size-body);
		font-weight: var(--type-sans-weight-emphasis);
		color: var(--color-text-body);
		margin: 2rem 0 0.5rem 0;
		letter-spacing: 0.01em;
		line-height: var(--type-sans-leading-tight);
		max-width: 32ch;
	}

	.project-content :global(p) {
		font-family: var(--font-sans);
		font-size: var(--type-sans-size-body);
		font-weight: var(--type-sans-weight-regular);
		color: var(--color-text-body);
		margin: 0 0 1rem 0;
		line-height: var(--type-sans-leading-reading);
		max-width: var(--text-measure);
		text-wrap: pretty;
	}

	.project-content :global(li) {
		font-family: var(--font-sans);
		font-size: var(--type-sans-size-body);
		font-weight: var(--type-sans-weight-regular);
		color: var(--color-text-body);
		margin: 0 0 0.35rem 0;
		line-height: var(--type-sans-leading-relaxed);
		max-width: var(--text-measure);
		text-wrap: pretty;
	}

	.project-content :global(strong),
	.project-content :global(b) {
		font-family: var(--font-sans);
		font-weight: var(--type-sans-weight-emphasis);
		color: var(--color-text-body);
	}

	.project-content :global(ul),
	.project-content :global(ol) {
		padding-left: 1.25rem;
		margin: 0 0 1rem 0;
	}

	.project-content :global(ul) {
		list-style-type: disc;
	}

	.project-content :global(.project-badges) {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 0 0 1rem 0;
		padding: 0;
		list-style: none;
	}

	.project-content :global(.project-badges li) {
		margin: 0;
		max-width: none;
		display: inline-block;
		padding: 0.1rem 0.65rem;
		border: 1px solid var(--color-border-soft);
		background: var(--color-surface-paper);
		box-shadow: 1px 2px 3px var(--color-shadow-soft);
		font-size: 1.5rem;
		font-family: var(--font-handwriting);
		letter-spacing: 0.02em;
		color: var(--color-text-handwriting);
		line-height: 1.2;
	}

	.project-content :global(.project-badges li:nth-child(3n + 1)) {
		transform: rotate(-0.9deg) translateY(-0.5px);
	}

	.project-content :global(.project-badges li:nth-child(3n + 2)) {
		transform: rotate(0.65deg) translateY(0.35px);
	}

	.project-content :global(.project-badges li:nth-child(3n + 3)) {
		transform: rotate(-0.45deg) translateY(0.2px);
	}

	.project-content :global(ol) {
		list-style-type: decimal;
	}

	.project-content :global(.inline-gallery) {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, max-content));
		justify-content: start;
		column-gap: 1rem;
		row-gap: 1.35rem;
		margin: 0 0 1.5rem 0;
	}

	.project-content :global(.inline-gallery__frame) {
		position: relative;
		width: 100%;
		max-width: clamp(16rem, 23vw, 21rem);
		justify-self: start;
		padding-top: calc(var(--size-project-tape-height) * 0.5);
		min-width: 0;
	}

	.project-content :global(.inline-gallery__frame::before) {
		content: "";
		position: absolute;
		top: calc(var(--size-project-tape-height) * 0.5);
		left: 50%;
		width: var(--size-project-tape-width);
		height: var(--size-project-tape-height);
		transform: translate(-50%, -50%)
			rotate(calc(var(--inline-gallery-tilt, 0deg) + 1.2deg));
		background: var(--color-tape);
		pointer-events: none;
		z-index: 2;
	}

	.project-content :global(.inline-gallery__tile) {
		display: flex;
		flex-direction: column;
		position: relative;
		width: 100%;
		min-height: clamp(7rem, 16vh, 10rem);
		background: var(--color-accent-lime);
		border: 8px solid var(--color-surface-page);
		box-shadow: var(--shadow-paper-medium);
		overflow: hidden;
		margin: 0;
		transform: rotate(var(--inline-gallery-tilt, 0deg))
			translateY(var(--inline-gallery-shift, 0px));
	}

	.project-content :global(.inline-gallery__image) {
		display: block;
		width: 100%;
		height: 100%;
		flex: 1;
		object-fit: cover;
	}

	.project-content :global(.inline-gallery__caption) {
		font-family: var(--font-sans);
		font-size: 0.9rem;
		line-height: 1.4;
		margin: 0;
		padding: 0.75rem 0.85rem 0.8rem;
		background: var(--color-surface-paper);
	}

	.project-content :global(.inline-gallery__frame:nth-child(4n + 1)) {
		--inline-gallery-tilt: -0.2deg;
		--inline-gallery-shift: -1px;
	}

	.project-content :global(.inline-gallery__frame:nth-child(4n + 2)) {
		--inline-gallery-tilt: -0.3deg;
		--inline-gallery-shift: 1px;
	}

	.project-content :global(.inline-gallery__frame:nth-child(4n + 3)) {
		--inline-gallery-tilt: 0.2deg;
		--inline-gallery-shift: -1px;
	}

	.project-content :global(.inline-gallery__frame:nth-child(4n + 4)) {
		--inline-gallery-tilt: -0.2deg;
		--inline-gallery-shift: 1px;
	}

	.section-handwriting-list :global(li) {
		font-family: var(--font-handwriting);
		font-size: clamp(1.25rem, 0.5vw + 1rem, 1.5rem);
		color: inherit;
		text-wrap: balance;
		line-height: 1.15;
		margin-top: 1rem;
	}

	@media (max-width: 1240px) {
		.section {
			grid-template-columns: 1fr;
			gap: 1rem;
		}

		.project-content :global(.inline-gallery__tile) {
			max-width: none;
		}

		.project-content :global(.inline-gallery__frame) {
			max-width: min(100%, 28rem);
		}
	}

	@media (max-width: 1142px) {
		.project-shell {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.project-content {
			padding-inline: 0;
		}

		.project-content :global(h1) {
			font-size: clamp(3rem, 14vw, 4rem);
			margin-bottom: 0.5rem;
		}

		.project-content :global(h3) {
			font-size: clamp(2.1rem, 9vw, 2.8rem);
		}

		.project-content :global(.inline-gallery) {
			grid-template-columns: 1fr;
		}
	}
</style>
