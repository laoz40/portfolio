---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import type {
	CarouselItem,
	CaseStudySection,
	SectionMedia,
} from "./caseStudySections";
import InlineGallery from "./inline/InlineGallery.svelte";
import InlineImage from "./inline/InlineImage.svelte";
import Sidebar from "./Sidebar.svelte";
import SectionCarouselMedia from "./media/SectionCarouselMedia.svelte";
import SectionImageMedia from "./media/SectionImageMedia.astro";
import SectionLinkButtons from "./SectionLinkButtons.astro";
import SectionVideoMedia from "./media/SectionVideoMedia.astro";

function getYouTubeVideoId(url: string): string | undefined {
	try {
		const parsedUrl = new URL(url);
		const shortCode =
			parsedUrl.hostname === "youtu.be"
				? parsedUrl.pathname.slice(1)
				: undefined;

		if (shortCode) {
			return shortCode;
		}

		const embedCode = parsedUrl.pathname.match(/^\/embed\/([^/?#]+)/)?.[1];

		if (embedCode) {
			return embedCode;
		}

		return parsedUrl.searchParams.get("v") ?? undefined;
	} catch {
		return undefined;
	}
}

function resolveSectionMedia(
	explicitMedia?: SectionMedia,
	frontmatterMedia?: SectionMedia,
): SectionMedia | undefined {
	const media = explicitMedia ?? frontmatterMedia;

	if (!media) {
		return undefined;
	}

	if (media.type === "youtube") {
		const videoId =
			media.videoId ?? (media.url ? getYouTubeVideoId(media.url) : undefined);

		if (!videoId) {
			return undefined;
		}

		return {
			...media,
			videoId,
		};
	}

	return media;
}

function getCarouselItems(resolvedMedia?: SectionMedia): CarouselItem[] {
	if (resolvedMedia?.type === "carousel" && resolvedMedia.items.length > 0) {
		return resolvedMedia.items;
	}

	return [];
}

type SectionLinks = Array<{
	label: string;
	href: string;
	fill: string;
}>;

type InlineGallery = {
	id: string;
	items: Array<{
		image: ImageMetadata;
		alt: string;
		caption?: string;
	}>;
};

type InlineImage = {
	id: string;
	image: {
		src: string;
		width: number;
		height: number;
	};
	alt: string;
	caption?: string;
};

type SectionFrontmatterExtras = {
	links?: SectionLinks;
	ariaLabel?: string;
	extraClass?: string;
	media?: SectionMedia;
	variant?: CaseStudySection["variant"];
};

type SectionContentFrontmatter = {
	section?: SectionFrontmatterExtras;
	inlineGalleries?: InlineGallery[];
	inlineImages?: InlineImage[];
};

type SectionMediaKind = "none" | "carousel" | "video" | "image";

type ResolvedSectionData = {
	variant: NonNullable<CaseStudySection["variant"]>;
	sectionClass: string | undefined;
	sectionProps: Record<string, unknown>;
	sectionLinks: SectionLinks;
	linksAriaLabel: string | undefined;
	inlineGalleries: InlineGallery[];
	inlineImages: InlineImage[];
	carouselItems: ReturnType<typeof getCarouselItems>;
	mediaKind: SectionMediaKind;
	imageMedia: Extract<SectionMedia, { type: "image" }> | undefined;
	videoMedia: Extract<SectionMedia, { type: "youtube" }> | undefined;
};

function getSectionFrontmatter(
	section: CaseStudySection,
): SectionContentFrontmatter {
	return (section.frontmatter as SectionContentFrontmatter | undefined) ?? {};
}

function getSectionVariant(
	section: CaseStudySection,
	frontmatterSection?: SectionFrontmatterExtras,
): NonNullable<CaseStudySection["variant"]> {
	return section.variant ?? frontmatterSection?.variant ?? "contentOnly";
}

function getMediaKind(
	variant: NonNullable<CaseStudySection["variant"]>,
	resolvedMedia?: SectionMedia,
): SectionMediaKind {
	if (variant === "contentOnly") {
		return "none";
	}

	if (variant === "carousel") {
		return "carousel";
	}

	if (resolvedMedia?.type === "youtube") {
		return "video";
	}

	if (resolvedMedia?.type === "image") {
		return "image";
	}

	return "none";
}

function getSectionRenderState(section: CaseStudySection): ResolvedSectionData {
	const frontmatter = getSectionFrontmatter(section);
	const frontmatterSection = frontmatter.section;
	const variant = getSectionVariant(section, frontmatterSection);
	const resolvedMedia = resolveSectionMedia(
		section.media,
		frontmatterSection?.media,
	);
	const videoMedia =
		resolvedMedia?.type === "youtube" ? resolvedMedia : undefined;
	const imageMedia =
		resolvedMedia?.type === "image" ? resolvedMedia : undefined;
	const mediaKind = getMediaKind(variant, resolvedMedia);

	return {
		variant,
		sectionClass: section.extraClass ?? frontmatterSection?.extraClass,
		sectionProps: section.props ?? {},
		sectionLinks: frontmatterSection?.links ?? [],
		linksAriaLabel: frontmatterSection?.ariaLabel,
		inlineGalleries: frontmatter.inlineGalleries ?? [],
		inlineImages: frontmatter.inlineImages ?? [],
		carouselItems: getCarouselItems(resolvedMedia),
		mediaKind,
		imageMedia,
		videoMedia,
	};
}

const { sections, headingSelector = "h2" } = Astro.props as {
	sections: CaseStudySection[];
	headingSelector?: string;
};
---

<div
	class="project-shell mx-auto mt-4 grid w-full grid-cols-[13rem_minmax(0,1fr)] items-start gap-10 max-[1142px]:grid-cols-1">
	<Sidebar
		client:load
		headingSelector={headingSelector}
	/>
	<article
		class="project-content flex w-full flex-col gap-12 pl-4 max-sm:px-0"
		data-scrollspy-root>
		{
			sections.map((section) => {
				const SectionComponent = section.Component;
				const {
					variant,
					sectionClass,
					sectionProps,
					sectionLinks,
					linksAriaLabel,
					inlineGalleries,
					inlineImages,
					carouselItems,
					mediaKind,
					imageMedia,
					videoMedia,
				} = getSectionRenderState(section);

				return (
					<section
						class:list={[
							"section grid min-w-0 grid-cols-[minmax(0,var(--section-copy-max-width))_minmax(18rem,var(--section-media-column-width,var(--section-media-max-width)))] items-start justify-center gap-x-12 gap-y-8 max-[1450px]:grid-cols-1 max-[1450px]:gap-4",
							`section--${variant}`,
							sectionClass,
						]}>
						<div class="section-copy min-w-0">
							<SectionComponent {...sectionProps} />
							{inlineGalleries.map((gallery) => (
								<InlineGallery
									client:load
									galleryId={gallery.id}>
									<template>
										<div class="inline-gallery grid grid-cols-[repeat(2,minmax(0,max-content))] justify-start gap-x-4 gap-y-[1.35rem] max-sm:grid-cols-1">
											{gallery.items.map((item) => (
												<div class="inline-gallery__frame relative w-full max-w-84 min-w-0 justify-self-start pt-[calc(var(--size-project-tape-height)*0.5)] max-[1450px]:max-w-[min(100%,28rem)]">
													<figure class="inline-gallery__tile paper-frame">
														<Image
															class="inline-gallery__image"
															src={item.image}
															alt={item.alt}
															width={item.image.width}
															height={item.image.height}
															loading="lazy"
															decoding="async"
														/>
														{item.caption ? (
															<figcaption class="inline-gallery__caption">
																{item.caption}
															</figcaption>
														) : null}
													</figure>
												</div>
											))}
										</div>
									</template>
								</InlineGallery>
							))}
							{inlineImages.map((item) => (
								<InlineImage
									client:load
									imageId={item.id}>
									<template>
										<div
											class="inline-image-frame taped-frame relative mb-6 w-full max-w-[calc(var(--text-measure)*1.4)] pt-[calc(var(--size-project-tape-height)*0.5)]"
											style={`--inline-image-max-width: ${item.image.width}px; --inline-image-aspect-ratio: ${item.image.width} / ${item.image.height};`}>
											<div class="inline-image paper-frame">
												<img
													class="inline-image__asset"
													src={item.image.src}
													alt={item.alt}
													width={item.image.width}
													height={item.image.height}
													loading="lazy"
													decoding="async"
												/>
											</div>
											{item.caption ? (
												<p class="inline-image__caption">{item.caption}</p>
											) : null}
										</div>
									</template>
								</InlineImage>
							))}
							{sectionLinks.length > 0 ? (
								<SectionLinkButtons
									links={sectionLinks}
									ariaLabel={linksAriaLabel}
								/>
							) : null}
						</div>
						{mediaKind === "carousel" ? (
							<SectionCarouselMedia
								client:visible
								items={carouselItems}
							/>
						) : null}
						{mediaKind === "video" && videoMedia ? (
							<SectionVideoMedia
								videoId={videoMedia.videoId}
								title={videoMedia.title}
							/>
						) : null}
						{mediaKind === "image" && imageMedia ? (
							<SectionImageMedia
								image={imageMedia.image}
								alt={imageMedia.alt}
							/>
						) : null}
					</section>
				);
			})
		}
	</article>
</div>

<style>
	.section:nth-of-type(odd) {
		--section-media-tilt: -0.4deg;
	}

	.section:nth-of-type(even) {
		--section-media-tilt: 0.4deg;
	}

	.section {
		width: min(
			100%,
			calc(
				var(--section-copy-max-width) +
					var(--section-media-column-width, var(--section-media-max-width)) +
					3rem
			)
		);
		margin-inline: auto;
	}

	.section--featured :global(.section-media-frame) {
		grid-column: 1 / -1;
		width: 100%;
		justify-self: center;
	}

	.section--featured :global(.section-media--embed) {
		min-height: 0;
	}

	.section--carousel :global(.section-carousel) {
		position: static;
		grid-column: 1 / -1;
	}

	.section--carousel .section-copy {
		grid-column: 1;
		justify-self: start;
	}

	.section--carousel :global(.section-carousel-slide) {
		min-height: 0;
	}

	.project-content {
		--text-measure: 66ch;
		--section-copy-max-width: 44rem;
		--section-media-max-width: 28rem;
		--section-stack-max-width: 44rem;
		margin-inline: 0;
	}

	@media (min-width: 1450.02px) {
		.project-content {
			--section-media-visual-max-width: 36rem;
		}
	}

	.section-copy {
		width: min(100%, var(--section-copy-max-width));
		justify-self: center;
	}

	.project-content :global(h2) {
		scroll-margin-top: calc(var(--nav-offset) + 1rem);
	}

	.project-content :global(h1) {
		font-family: var(--font-handwriting);
		font-size: var(--type-hand-size-display-lg);
		font-weight: 700;
		line-height: 0.95;
		margin: 0 0 1rem 0;
	}

	.project-content :global(h2) {
		font-family: var(--font-handwriting);
		font-size: var(--type-hand-size-title-sm);
		font-weight: 400;
		color: var(--color-text-body);
		letter-spacing: 0.01em;
		line-height: 1;
		margin: 2rem 0 1rem 0;
	}

	.project-content :global(h3) {
		font-family: var(--font-handwriting);
		font-size: var(--type-hand-size-display-sm);
		font-weight: 700;
		line-height: 0.95;
		text-wrap: balance;
		margin-bottom: 1rem;
	}

	.project-content :global(h4) {
		font-family: var(--font-sans);
		font-size: var(--type-sans-size-body);
		font-weight: var(--type-sans-weight-emphasis);
		color: var(--color-text-body);
		margin: 2rem 0 0.5rem 0;
		letter-spacing: 0.01em;
		line-height: var(--type-sans-leading-tight);
		max-width: 32ch;
	}

	.project-content :global(p) {
		font-family: var(--font-sans);
		font-size: var(--type-sans-size-body);
		font-weight: var(--type-sans-weight-regular);
		color: var(--color-text-body);
		margin: 0 0 1rem 0;
		line-height: var(--type-sans-leading-reading);
		max-width: var(--text-measure);
		text-wrap: pretty;
	}

	.project-content :global(li) {
		font-family: var(--font-sans);
		font-size: var(--type-sans-size-body);
		font-weight: var(--type-sans-weight-regular);
		color: var(--color-text-body);
		margin: 0 0 0.5rem 0;
		line-height: var(--type-sans-leading-relaxed);
		max-width: var(--text-measure);
		text-wrap: pretty;
	}

	.project-content :global(strong),
	.project-content :global(b) {
		font-family: var(--font-sans);
		font-weight: var(--type-sans-weight-emphasis);
		color: var(--color-text-body);
	}

	.project-content :global(ul),
	.project-content :global(ol) {
		padding-left: 1.25rem;
		margin: 0 0 1rem 0;
	}

	.project-content :global(ul) {
		list-style-type: disc;
	}

	.project-content :global(.project-badges) {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 0 0 1rem 0;
		padding: 0;
		list-style: none;
	}

	.project-content :global(.project-badges li) {
		margin: 0;
		max-width: none;
		display: inline-block;
		padding: 0.1rem 0.65rem;
		border: 1px solid var(--color-border-soft);
		background: var(--color-surface-paper);
		box-shadow: 1px 2px 3px var(--color-shadow-soft);
		font-size: var(--type-hand-size-body);
		font-family: var(--font-handwriting);
		letter-spacing: 0.02em;
		color: var(--color-text-handwriting);
		line-height: 1.2;
	}

	.project-content :global(.project-badges li:nth-child(3n + 1)) {
		transform: rotate(-0.9deg) translateY(-0.5px);
	}

	.project-content :global(.project-badges li:nth-child(3n + 2)) {
		transform: rotate(0.65deg) translateY(0.35px);
	}

	.project-content :global(.project-badges li:nth-child(3n + 3)) {
		transform: rotate(-0.45deg) translateY(0.2px);
	}

	.project-content :global(ol) {
		list-style-type: decimal;
	}

	.project-content :global(.inline-gallery) {
		margin: 0 0 1.5rem 0;
	}

	.project-content :global(.inline-gallery__frame::before) {
		content: "";
		position: absolute;
		top: calc(var(--size-project-tape-height) * 0.5);
		left: 50%;
		width: var(--size-project-tape-width);
		height: var(--size-project-tape-height);
		transform: translate(-50%, -50%)
			rotate(calc(var(--inline-gallery-tilt, 0deg) + 1.2deg));
		background: var(--color-tape);
		pointer-events: none;
		z-index: 2;
	}

	.project-content :global(.inline-gallery__tile) {
		display: flex;
		flex-direction: column;
		position: relative;
		width: 100%;
		min-height: 9rem;
		overflow: hidden;
		margin: 0;
		transform: rotate(var(--inline-gallery-tilt, 0deg))
			translateY(var(--inline-gallery-shift, 0px));
	}

	.project-content :global(.inline-gallery__image) {
		display: block;
		width: 100%;
		height: 100%;
		flex: 1;
		object-fit: cover;
	}

	.project-content :global(.inline-gallery__caption) {
		font-family: var(--font-sans);
		font-size: 0.9rem;
		line-height: 1.4;
		margin: 0;
		padding: 0.75rem 0.85rem 0.8rem;
		background: var(--color-surface-paper);
	}

	.project-content :global(.inline-image) {
		position: relative;
		aspect-ratio: var(--inline-image-aspect-ratio);
		background: var(--color-accent-lime);
		overflow: hidden;
		transform: rotate(-0.35deg);
	}

	.project-content :global(.inline-image__asset) {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.project-content :global(.inline-image__caption) {
		font-family: var(--font-sans);
		font-size: 0.9rem;
		line-height: 1.4;
		margin: 0.6rem 0 0;
		max-width: var(--text-measure);
	}

	.project-content :global(.inline-gallery__frame:nth-child(4n + 1)) {
		--inline-gallery-tilt: -0.2deg;
		--inline-gallery-shift: -1px;
	}

	.project-content :global(.inline-gallery__frame:nth-child(4n + 2)) {
		--inline-gallery-tilt: -0.3deg;
		--inline-gallery-shift: 1px;
	}

	.project-content :global(.inline-gallery__frame:nth-child(4n + 3)) {
		--inline-gallery-tilt: 0.2deg;
		--inline-gallery-shift: -1px;
	}

	.project-content :global(.inline-gallery__frame:nth-child(4n + 4)) {
		--inline-gallery-tilt: -0.2deg;
		--inline-gallery-shift: 1px;
	}

	.section-handwriting-list :global(li) {
		font-family: var(--font-handwriting);
		font-size: var(--type-hand-size-label);
		color: inherit;
		text-wrap: balance;
		line-height: 1.15;
		margin-top: 1rem;
	}

	@media (max-width: 1450px) {
		.section {
			width: min(100%, var(--section-stack-max-width));
		}

		.section-copy {
			width: 100%;
			justify-self: stretch;
		}

		.section--carousel .section-copy {
			justify-self: stretch;
		}

		.project-content :global(.inline-gallery__tile) {
			max-width: none;
		}
	}

	@media (max-width: 640px) {
		.project-content :global(h1) {
			font-size: var(--type-hand-size-display-lg);
			margin-bottom: 0.5rem;
		}

		.project-content :global(h3) {
			font-size: var(--type-hand-size-display-sm);
		}

		.project-content :global(.inline-image) {
			transform: none;
		}

		.project-content :global(.inline-image-frame::before) {
			transform: translate(-50%, -50%) rotate(1.2deg);
		}
	}
</style>
