---
import ProjectLinkButtons from "./ProjectLinkButtons.astro";
import type { SectionLink } from "./caseStudySections";

const { links, ariaLabel = "Project links" } = Astro.props as {
	links: SectionLink[];
	ariaLabel?: string;
};
---

{
	links.length > 0 ? (
		<div class="section-link-buttons">
			<ProjectLinkButtons
				links={links}
				ariaLabel={ariaLabel}
			/>
		</div>
	) : null
}

<style>
	.section-link-buttons {
		display: flex;
		justify-content: flex-start;
		margin-top: 1.25rem;
	}

	@media (max-width: 640px) {
		.section-link-buttons {
			margin-top: 0.5rem;
		}
	}
</style>
