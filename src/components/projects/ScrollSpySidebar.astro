---
interface Props {
	rootSelector?: string;
	headingSelector?: string;
}

const { rootSelector = "[data-scrollspy-root]", headingSelector = "h2" } =
	Astro.props;
---

<aside
	class="scrollspy"
	data-scrollspy
	data-root-selector={rootSelector}
	data-heading-selector={headingSelector}>
	<nav aria-label="On this page">
		<ul
			class="scrollspy-list"
			data-scrollspy-list>
		</ul>
	</nav>
</aside>

<script is:inline>
	const slugifyHeadingText = (textValue) =>
		String(textValue)
			.toLowerCase()
			.trim()
			.replace(/[^a-z0-9\s-]/g, "")
			.replace(/\s+/g, "-")
			.replace(/-+/g, "-");

	const isValidHeading = (headingNode) =>
		headingNode instanceof HTMLElement &&
		typeof headingNode.textContent === "string" &&
		headingNode.textContent.trim().length > 0;

	const ensureHeadingId = (headingNode, usedIds) => {
		if (headingNode.id) {
			usedIds.add(headingNode.id);
			return headingNode.id;
		}

		const baseId = slugifyHeadingText(headingNode.textContent) || "section";
		let nextId = baseId;
		let suffix = 2;

		while (document.getElementById(nextId) || usedIds.has(nextId)) {
			nextId = `${baseId}-${suffix}`;
			suffix += 1;
		}

		headingNode.id = nextId;
		usedIds.add(nextId);
		return nextId;
	};

	const getItemsFromHeadings = (contentRoot, headingSelector) => {
		const usedIds = new Set();
		const seenTargets = new Set();
		const items = [];

		const headings = Array.from(
			contentRoot.querySelectorAll(headingSelector),
		).filter(isValidHeading);

		for (const heading of headings) {
			const id = ensureHeadingId(heading, usedIds);
			const target = heading.closest("section") || heading;

			if (seenTargets.has(target)) {
				continue;
			}

			seenTargets.add(target);
			items.push({
				id,
				label: heading.textContent.trim(),
				target,
			});
		}

		return items;
	};

	const pickActiveTarget = (entriesByTarget, anchorY) => {
		const visibleEntries = Array.from(entriesByTarget.values());
		if (visibleEntries.length === 0) {
			return null;
		}

		const sortedByTopDesc = visibleEntries.sort(
			(entryA, entryB) =>
				entryB.boundingClientRect.top - entryA.boundingClientRect.top,
		);

		const crossingEntry = sortedByTopDesc.find(
			(entry) =>
				entry.boundingClientRect.top <= anchorY &&
				entry.boundingClientRect.bottom >= anchorY,
		);
		if (crossingEntry) {
			return crossingEntry.target;
		}

		const nearestAboveEntry = sortedByTopDesc.find(
			(entry) => entry.boundingClientRect.top <= anchorY,
		);
		return (nearestAboveEntry || sortedByTopDesc[0]).target;
	};

	const initScrollSpy = () => {
		const sidebarRoots = document.querySelectorAll("[data-scrollspy]");

		for (const sidebarRoot of sidebarRoots) {
			if (sidebarRoot.dataset.scrollspyReady === "true") {
				continue;
			}

			const listElement = sidebarRoot.querySelector("[data-scrollspy-list]");
			if (!listElement) {
				continue;
			}

			const rootSelector =
				sidebarRoot.getAttribute("data-root-selector") ||
				"[data-scrollspy-root]";
			const headingSelector =
				sidebarRoot.getAttribute("data-heading-selector") || "h2";
			const contentRoot = document.querySelector(rootSelector);

			if (!contentRoot) {
				listElement.replaceChildren();
				continue;
			}

			const items = getItemsFromHeadings(contentRoot, headingSelector);

			listElement.replaceChildren();

			if (items.length === 0) {
				sidebarRoot.setAttribute("hidden", "");
				sidebarRoot.dataset.scrollspyReady = "true";
				continue;
			}

			sidebarRoot.removeAttribute("hidden");

			const linksById = new Map();
			const targetIdByElement = new Map();

			for (const item of items) {
				const listItem = document.createElement("li");
				const linkElement = document.createElement("a");
				const linkLabelElement = document.createElement("span");
				linkElement.className = "scrollspy-link";
				linkElement.href = `#${item.id}`;
				linkLabelElement.className = "scrollspy-link-text highlight-text";
				linkLabelElement.style.setProperty(
					"--highlight-colour",
					"var(--color-highlight-yellow-strong)",
				);
				linkLabelElement.textContent = item.label;
				linkElement.append(linkLabelElement);
				listItem.append(linkElement);
				listElement.append(listItem);
				linksById.set(item.id, linkElement);
				targetIdByElement.set(item.target, item.id);
			}

			const setActiveHeading = (activeId) => {
				for (const [headingId, linkElement] of linksById.entries()) {
					const isActive = headingId === activeId;
					linkElement.classList.toggle("is-active", isActive);
					if (isActive) {
						linkElement.setAttribute("aria-current", "location");
					} else {
						linkElement.removeAttribute("aria-current");
					}
				}
			};

			setActiveHeading(items[0].id);

			if (!("IntersectionObserver" in window)) {
				continue;
			}

			const intersectingTargets = new Map();

			const observer = new IntersectionObserver(
				(entries) => {
					for (const entry of entries) {
						if (entry.isIntersecting) {
							intersectingTargets.set(entry.target, entry);
						} else {
							intersectingTargets.delete(entry.target);
						}
					}

					const anchorY = window.innerHeight * 0.2;
					const nextActiveTarget = pickActiveTarget(
						intersectingTargets,
						anchorY,
					);
					if (!nextActiveTarget) {
						return;
					}

					const nextActiveId = targetIdByElement.get(nextActiveTarget);
					if (!nextActiveId) {
						return;
					}

					setActiveHeading(nextActiveId);
				},
				{
					rootMargin: "-20% 0px -60% 0px",
					threshold: [0, 0.25, 0.5],
				},
			);

			for (const item of items) {
				observer.observe(item.target);
			}

			sidebarRoot.dataset.scrollspyReady = "true";
		}
	};

	initScrollSpy();
	document.addEventListener("astro:page-load", initScrollSpy);
</script>

<style>
	.scrollspy {
		position: sticky;
		top: calc(var(--nav-offset) + 1rem);
		align-self: start;
		padding-top: 0.5rem;
		padding-left: 0.75rem;
	}

	.scrollspy-list {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.22rem;
	}

	.scrollspy :global(.scrollspy-link) {
		display: inline-flex;
		padding: 0.2rem 0;
		font-size: 1.5rem;
		font-weight: 400;
		line-height: 1.25;
		text-decoration: none;
		transition:
			color 180ms ease,
			transform 180ms ease;
	}

	.scrollspy :global(.scrollspy-link:hover),
	.scrollspy :global(.scrollspy-link:focus-visible) {
		transform: translateX(0.12rem);
	}

	.scrollspy :global(.scrollspy-link.is-active) {
		font-weight: 700;
	}

	.scrollspy :global(.scrollspy-link-text) {
		--highlight-top: 0.1em;
		--highlight-bottom: 0.1em;
	}

	.scrollspy :global(.scrollspy-link:hover .scrollspy-link-text)::before,
	.scrollspy
		:global(.scrollspy-link:focus-visible .scrollspy-link-text)::before,
	.scrollspy :global(.scrollspy-link.is-active .scrollspy-link-text)::before {
		transform: var(
			--highlight-transform-active,
			scaleX(1) skewX(-4deg) rotate(-1.2deg)
		);
		opacity: 1;
	}

	@media (max-width: 1142px) {
		.scrollspy {
			display: none;
		}
	}

	@media (max-width: 980px) {
		.scrollspy {
			display: none;
		}
	}
</style>
