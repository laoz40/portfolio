---
type Props = {
	tools: string[];
	projectTitle: string;
};

const { tools, projectTitle } = Astro.props as Props;
---

<div class="tool-badges-shell">
	<ul
		class="tool-badges"
		aria-label={`${projectTitle} tools used`}>
		{
			tools.map((tool) => (
				<li class="tool-badge">
					<span class="tool-badge-shape">{tool}</span>
				</li>
			))
		}
	</ul>
</div>

<style>
	.tool-badges-shell {
		margin: 0;
		padding: 0;
	}

	.tool-badges {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.tool-badge {
		padding: 0;
	}

	.tool-badge:nth-child(3n + 1) {
		transform: rotate(-0.9deg) translateY(-0.5px);
	}

	.tool-badge:nth-child(3n + 2) {
		transform: rotate(0.65deg) translateY(0.35px);
	}

	.tool-badge:nth-child(3n + 3) {
		transform: rotate(-0.45deg) translateY(0.2px);
	}

	.tool-badge-shape {
		position: relative;
		display: inline-block;
		padding: 0.16rem 0.7rem;
		border: 1px solid var(--color-border-soft);
		font-family: var(--font-handwriting);
		font-size: var(--type-hand-size-label-sm);
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--color-text-handwriting);
		background: var(--color-surface-paper);
		box-shadow: 1px 2px 3px var(--color-shadow-soft);
	}
</style>
