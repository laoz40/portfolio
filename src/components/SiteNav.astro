---
import NavLink from "./NavLink.astro";
---

<nav transition:animate="none">
	<div class="nav-brand font-bold">
		<NavLink
			href="/"
			variant="lime"
			selectable>
			Leo Zhou
		</NavLink>
	</div>

	<div class="nav-links">
		<NavLink
			href="/projects"
			variant="yellow">
			Projects
		</NavLink>
		<NavLink
			href="/about"
			variant="sky">
			About
		</NavLink>
		<NavLink
			href="/contact"
			variant="lime">
			Contact
		</NavLink>
	</div>
</nav>

<style>
	nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		width: 100%;
		box-sizing: border-box;
		z-index: 50;
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		padding-inline: var(--page-gutter);
	}

	.nav-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		align-items: center;
		gap: clamp(0.25rem, 1.2vw, 2.5rem);
		min-width: 0;
	}

	@media (max-width: 820px) {
		nav {
			padding-top: 0.25rem;
			padding-bottom: 0.25rem;
		}

		.nav-brand {
			flex: 1 1 auto;
		}

		.nav-links {
			flex: 1 1 auto;
		}
	}

	@media (max-width: 580px) {
		nav {
			align-items: flex-start;
		}

		.nav-links {
			justify-content: flex-start;
		}
	}
</style>
