---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

const { media } = Astro.props as {
	media: {
		image: ImageMetadata;
		alt: string;
		caption?: string;
		variant?: "taped" | "raw";
	};
};

const variant = media.variant ?? "taped";
const isTaped = variant === "taped";
---

<figure
	class:list={[
		"about-media-figure m-0 w-full",
		isTaped ? "about-media-figure--taped" : "about-media-figure--raw",
	]}
	style={`--about-media-max-width: ${media.image.width}px; --about-media-aspect-ratio: ${media.image.width} / ${media.image.height};`}>
	{
		isTaped ? (
			<div
				class="about-media-frame taped-frame relative w-full min-w-0"
				style="--tape-top: calc(var(--size-project-tape-height) * 0.2);">
				<div class="about-media paper-frame about-media--taped">
					<Image
						class="about-media-image"
						src={media.image}
						alt={media.alt}
						width={media.image.width}
						height={media.image.height}
						loading="lazy"
						decoding="async"
					/>
				</div>
			</div>
		) : (
			<Image
				class="about-media-image about-media-image--raw"
				src={media.image}
				alt={media.alt}
				width={media.image.width}
				height={media.image.height}
				loading="lazy"
				decoding="async"
			/>
		)
	}
	{
		isTaped ? (
			<figcaption class="about-media-caption">
				{media.caption ?? media.alt}
			</figcaption>
		) : null
	}
</figure>

<style>
	.about-media-figure {
		width: min(100%, var(--about-media-max-width));
	}

	.about-media-figure--taped {
		padding-top: calc(var(--size-project-tape-height) * 0.5);
	}

	.about-media {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		aspect-ratio: var(--about-media-aspect-ratio);
		max-height: 24rem;
		overflow: hidden;
	}

	.about-media-image {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
	}

	.about-media-image--raw {
		width: auto;
		max-width: 100%;
		max-height: 24rem;
		height: auto;
		object-fit: contain;
	}

	.about-media-caption {
		font-family: var(--font-handwriting);
		font-size: var(--type-hand-size-label);
		line-height: 1.4;
		margin: 0.75rem 0 0;
	}

	@media (max-width: 760px) {
		.about-media-figure {
			width: min(100%, 26rem, var(--about-media-max-width));
		}

		.about-media,
		.about-media-image--raw {
			max-height: 22rem;
		}
	}
</style>
