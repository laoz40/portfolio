---
import HighlightText from "../ui/HighlightText.astro";

const { href, variant = "yellow", selectable = false } = Astro.props;
---

<a
	class="nav-link"
	href={href}>
	<HighlightText
		class="nav-link-text"
		variant={variant}
		selectable={selectable}>
		<slot />
	</HighlightText>
</a>

<style>
	.nav-link {
		display: inline-block;
		text-decoration: none;
	}

	.nav-link :global(.nav-link-text) {
		font-size: 1.9rem;
		line-height: 1.1;
		--highlight-top: 0.8em;
		--highlight-bottom: 0.8em;
		--highlight-left: -0.04em;
		--highlight-right: -0.03em;
		padding: clamp(0.6rem, 1.4vw, 1.5rem) clamp(0.45rem, 1vw, 1rem);
		transition: transform 120ms ease;
	}

	.nav-link :global(.nav-link-text:not(.selectable)) {
		user-select: none;
	}

	.nav-link :global(.nav-link-text.selectable) {
		user-select: text;
	}

	.nav-link:hover :global(.nav-link-text)::before,
	.nav-link:focus-visible :global(.nav-link-text)::before {
		transform: var(
			--highlight-transform-active,
			scaleX(1) skewX(-4deg) rotate(-1.2deg)
		);
		opacity: 1;
	}

	.nav-link:active :global(.nav-link-text) {
		transform: scale(0.95);
	}
</style>
