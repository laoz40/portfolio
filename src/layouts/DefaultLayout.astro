---
import NavLink from "../components/NavLink.astro";
import BgLight from "../components/BgLight.jsx";
import { ClientRouter, slide } from "astro:transitions";
import "../styles/global.css";

const { title, home = false } = Astro.props;

const projectsHlColour = "rgb(255 230 0 / 0.7)";
const aboutHlColour = "rgb(0 197 255 / 0.7)";
const contactHlColour = "rgb(50 255 50 / 0.7)";
---

<html
	lang="en"
	transition:animate="none">
	<head>
		<meta charset="utf-8" />
		<link
			rel="icon"
			type="image/svg+xml"
			href="/favicon.svg"
		/>
		<link
			rel="icon"
			href="/favicon.ico"
		/>
		<meta
			name="viewport"
			content="width=device-width"
		/>
		<meta
			name="generator"
			content={Astro.generator}
		/>
		<title>Leo Zhou - {title}</title>
		<ClientRouter />
	</head>

	<body>
		<BgLight client:load>
			<nav
				transition:animate="none">
				<div class="nav-brand font-bold">
					<NavLink
						href="/"
						hlColour={contactHlColour}
						selectable>
						Leo Zhou
					</NavLink>
				</div>

				<div class="nav-links">
					<NavLink
						href="/projects"
						hlColour={projectsHlColour}>
						Projects
					</NavLink>
					<NavLink
						href="/about"
						hlColour={aboutHlColour}>
						About
					</NavLink>
					<NavLink
						href="/contact"
						hlColour={contactHlColour}>
						Contact
					</NavLink>
				</div>
			</nav>
			<main
				class:list={{ home }}
				transition:animate={slide({ duration: "0.35s" })}>
				<slot />
			</main>

			<footer
				id="contact"
				aria-label="Social and contact links"
				transition:animate="none">
				<NavLink
					href="mailto:hello@example.com"
					hlColour={contactHlColour}>
					Email
				</NavLink>
				<NavLink
					href="https://www.linkedin.com"
					hlColour={contactHlColour}>
					LinkedIn
				</NavLink>
				<NavLink
					href="https://github.com"
					hlColour={contactHlColour}>
					Github
				</NavLink>
				<NavLink
					href="/resume"
					hlColour={contactHlColour}>
					Resume
				</NavLink>
			</footer>
		</BgLight>
		<script is:inline>
			const routeOrder = ["/", "/projects", "/projects/sprout", "/about", "/contact"];
			const routeIndex = new Map(routeOrder.map((path, index) => [path, index]));

			const normalizePathname = (pathLike) => {
				if (!pathLike) {
					return "/";
				}

				let pathname = pathLike;
				try {
					pathname = new URL(pathLike, window.location.origin).pathname;
				} catch {
					pathname = String(pathLike);
				}

				if (pathname.length > 1 && pathname.endsWith("/")) {
					pathname = pathname.slice(0, -1);
				}

				return pathname || "/";
			};

			const getPathIndex = (pathname) => {
				if (routeIndex.has(pathname)) {
					return routeIndex.get(pathname);
				}

				if (pathname.startsWith("/projects/")) {
					return routeIndex.get("/projects/sprout");
				}

				return undefined;
			};

			if (!window.__siteOrderTransitionsReady) {
				window.__siteOrderTransitionsReady = true;

				document.addEventListener("astro:before-preparation", (event) => {
					const fromPath = normalizePathname(event.from?.url?.pathname ?? event.from?.pathname);
					const toPath = normalizePathname(event.to?.url?.pathname ?? event.to?.pathname);

					const fromIndex = getPathIndex(fromPath);
					const toIndex = getPathIndex(toPath);

					if (fromIndex === undefined || toIndex === undefined || fromIndex === toIndex) {
						return;
					}

					event.direction = toIndex > fromIndex ? "forward" : "back";
				});
			}
		</script>
	</body>
</html>

<style>
	:root {
		--page-gutter: clamp(1rem, 4vw, 8rem);
		--nav-offset: clamp(4.25rem, 8vw, 6rem);
	}

	nav {
		top: 0;
		left: 0;
		right: 0;
		width: 100%;
		box-sizing: border-box;
		z-index: 50;
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		padding-inline: var(--page-gutter);
	}

	.nav-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		align-items: center;
		gap: clamp(0.25rem, 1.2vw, 2.5rem);
		min-width: 0;
	}

	nav {
		position: fixed;
	}

	main {
		flex: 1;
		display: flex;
		flex-direction: column;
		min-height: 100svh;
		margin-inline: var(--page-gutter);
		padding-top: var(--nav-offset);
		min-width: 0;
	}

	main.home {
		padding-top: 0;
	}

	footer {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		margin-top: 5rem;
		flex-wrap: wrap;
	}

	@media (max-width: 820px) {
		nav {
			padding-top: 0.25rem;
			padding-bottom: 0.25rem;
		}

		.nav-brand {
			flex: 1 1 auto;
		}

		.nav-links {
			flex: 1 1 auto;
		}
	}

	@media (max-width: 580px) {
		nav {
			align-items: flex-start;
		}

		.nav-links {
			justify-content: flex-start;
		}
	}

</style>
