---
import NavLink from '../components/NavLink.astro';
import BgLight from '../components/BgLight.jsx';
import '../styles/global.css';

const { title } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Leo Zhou - {title}</title>
	</head>

	<body>
		<BgLight client:load>
			<nav>
				<div class="font-bold">
					<NavLink href="/" hlColour="rgb(50 255 50 / 0.7)">Leo Zhou</NavLink>
				</div>
				<div class="flex gap-12">
					<NavLink href="/#projects" hlColour="rgb(255 230 0 / 0.7)">Projects</NavLink>
					<NavLink href="/#about" hlColour="rgb(0 197 255 / 0.7)">About</NavLink>
					<NavLink href="/#contact" hlColour="rgb(50 255 50 / 0.7)">Contact</NavLink>
				</div>
			</nav>
			<main>
				<slot />
			</main>
		</BgLight>
	</body>
</html>

<style>
	nav {
		position: sticky;
		top: 0;
		z-index: 50;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 8rem;
	}

	main {
		flex: 1;
		display: flex;
		flex-direction: column;
		margin: 0 8rem;
	}
</style>
