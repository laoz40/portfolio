---
import DefaultLayout from "../layouts/DefaultLayout.astro";

import ImperfectButton from "../components/home/ImperfectButton.astro";
import ScrollDownArrow from "../components/home/ScrollDownArrow.astro";
---

<DefaultLayout
	title="Portfolio"
	home>
	<section id="hero">
		<h1>Welcome to Leo's Portfolio!</h1>

		<div class="flex flex-col">
			<h2>Front End Engineer</h2>
			<h2>UX Designer</h2>
		</div>

		<div class="hero-actions flex mt-32 gap-12 text-2xl">
			<ImperfectButton
				href="/projects"
				fill="var(--color-home-button-yellow)">
				Projects
			</ImperfectButton>
			<ImperfectButton
				href="/about"
				fill="var(--color-home-button-sky)">
				About
			</ImperfectButton>
		</div>

		<ScrollDownArrow href="#featured" />
	</section>

	<section id="featured">
		<h3>Featured Work</h3>
	</section>
</DefaultLayout>

<style>
	#hero {
		min-height: 100svh;
		width: 100%;
		box-sizing: border-box;
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
	}

	#featured {
		min-height: 100svh;
		padding-top: 6rem;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.1rem, 9vw, 5rem);
		font-weight: 700;
		letter-spacing: -0.04em;
		text-align: center;
	}

	h2 {
		margin: 0;
		font-size: clamp(1.7rem, 7vw, 4rem);
		line-height: 1;
		letter-spacing: -0.02em;
		text-align: center;
	}

	h3 {
		margin: 0;
		font-size: 2.5rem;
		font-weight: 700;
		line-height: 1;
		letter-spacing: -0.02em;
		text-align: center;
	}

	span {
		font-size: 2rem;
		text-align: center;
	}

	.hero-actions {
		flex-wrap: wrap;
		justify-content: center;
		margin-top: clamp(2rem, 9vw, 8rem);
		gap: clamp(0.75rem, 3vw, 3rem);
	}

	@media (max-width: 640px) {
		#hero {
			padding-top: 4.5rem;
		}
	}
</style>
