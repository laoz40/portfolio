---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import DefaultLayout from "../layouts/DefaultLayout.astro";
import HeroSketchCluster from "../components/home/HeroSketchCluster.astro";
import HeroLogoCluster from "../components/home/HeroLogoCluster.astro";
import ImperfectButton from "../components/home/ImperfectButton.astro";
import ScrollDownArrow from "../components/home/ScrollDownArrow.astro";
import HighlightText from "../components/ui/HighlightText.astro";
import ToolBadges from "../components/ui/ToolBadges.astro";
import { getEntry } from "astro:content";

type ProjectFrontmatter = {
	title: string;
	project: string;
	description: string;
	tools?: string[];
	coverImage?: ImageMetadata;
};

const horusEntry = await getEntry("horus", "00-intro");

if (!horusEntry) {
	throw new Error("Missing intro entry for: horus");
}

const horus = horusEntry.data as ProjectFrontmatter;
const heroTitle = "Welcome to Leo's Website!";
const heroTitleLines = ["Welcome to", "Leo's Website!"];
---

<DefaultLayout
	title="Portfolio"
	home>
	<section
		id="hero"
		class="relative flex min-h-svh w-full flex-col items-center justify-center gap-4 px-8 pt-0 pb-22 max-[1100px]:gap-3 max-[1100px]:px-6 max-[1100px]:pt-12 max-[1100px]:pb-24 max-[820px]:justify-start max-[820px]:px-4 max-[820px]:pt-64 max-[820px]:pb-24 max-sm:gap-2 max-sm:pt-72">
		<HeroSketchCluster />
		<HeroLogoCluster />

		<div
			class="hero-copy relative z-2 flex w-full max-w-216 flex-col items-center gap-4 max-[1100px]:max-w-136 max-[820px]:max-w-[24rem] max-sm:max-w-[20rem] max-sm:gap-[0.9rem]">
			<h1
				class="hero-title"
				aria-label={heroTitle}>
				{
					heroTitleLines.map((line) => (
						<span class="hero-title-line">
							<span
								class="hero-title-text"
								aria-hidden="true">
								{line}
							</span>
						</span>
					))
				}
			</h1>

			<div
				class="hero-roles flex flex-col items-center gap-[0.35rem] max-sm:gap-[0.2rem]">
				<h2>Full Stack Developer</h2>
				<h2>UX Designer</h2>
			</div>
		</div>

		<div
			class="hero-actions relative z-2 mt-4 flex flex-wrap items-center justify-center gap-6 max-[1100px]:mt-2 max-[820px]:mt-1 max-[420px]:max-w-60 max-[420px]:grid-cols-1 max-sm:mt-2 max-sm:mb-15 max-sm:grid max-sm:w-full max-sm:max-w-84 max-sm:grid-cols-2 max-sm:gap-0">
			<ImperfectButton
				href="/projects"
				fill="var(--color-home-button-yellow)">
				Projects
			</ImperfectButton>
			<ImperfectButton
				href="/about"
				fill="var(--color-home-button-sky)">
				About
			</ImperfectButton>
		</div>

		<div
			class="hero-footer absolute bottom-6 left-1/2 z-2 flex w-[calc(100%-2rem)] max-w-176 -translate-x-1/2 flex-col items-center gap-2 max-[1100px]:bottom-5 max-[820px]:max-w-136 max-sm:bottom-5 max-sm:w-[calc(100%-1.5rem)] max-sm:max-w-88 max-sm:gap-2">
			<p class="hero-note">
				This website wasn't hand-coded or vibe-coded. It was all hand-drawn.
			</p>
			<ScrollDownArrow href="#featured" />
		</div>
	</section>

	<section
		id="featured"
		class="flex min-h-svh flex-col items-center gap-8 pt-24 max-sm:pt-16">
		<h3>Featured Work</h3>
		<a
			class="project-card"
			href="/projects/horus"
			aria-label={`Open ${horus.title} project page`}>
			<div class="project-frame">
				<div
					class="preview"
					aria-hidden="true">
					{
						horus.coverImage ? (
							<Image
								class="preview-image"
								src={horus.coverImage}
								alt=""
								loading="eager"
								fetchpriority="high"
								decoding="async"
							/>
						) : null
					}
				</div>
				<div
					class="project-meta flex flex-1 flex-col justify-between px-0 pt-4 pb-[0.1rem]">
					<div class="flex flex-col gap-[0.7rem]">
						<div class="project-title flex flex-col items-start gap-[0.35rem]">
							<HighlightText
								tag="h4"
								variant="yellow"
								class="project-title-highlight">
								{horus.title}
							</HighlightText>
							<span class="project-subtitle">{horus.project}</span>
						</div>
						<p>{horus.description}</p>
					</div>
					<ToolBadges
						tools={horus.tools ?? []}
						projectTitle={horus.title}
					/>
				</div>
			</div>
		</a>
		<div class="flex w-full justify-center">
			<ImperfectButton
				href="/projects"
				fill="var(--color-home-button-yellow)">
				See more projects
			</ImperfectButton>
		</div>
	</section>
</DefaultLayout>

<script>
	import "../animation/heroAnimations.ts";
</script>

<style>
	h1 {
		margin: 0;
		font-size: var(--type-hand-size-display-lg);
		font-weight: 700;
		letter-spacing: -0.04em;
		line-height: 0.96;
		text-align: center;
		text-wrap: balance;
		max-width: 12ch;
	}

	.hero-title-line {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		overflow: hidden;
		width: fit-content;
		margin: 0 auto;
	}

	.hero-title-line + .hero-title-line {
		margin-top: 0.08em;
	}

	.hero-title-text {
		display: inline-block;
	}

	h2 {
		margin: 0;
		font-size: var(--type-hand-size-display-sm);
		line-height: 1.05;
		letter-spacing: -0.02em;
		text-align: center;
		text-wrap: balance;
	}

	h3 {
		margin: 0;
		font-size: var(--type-hand-size-display-md);
		font-weight: 700;
		line-height: 1;
		text-align: center;
	}

	.project-card {
		display: flex;
		width: min(100%, 37.25rem);
		color: var(--color-text-body);
		text-decoration: none;
		margin-top: 2rem;
	}

	.project-frame {
		position: relative;
		display: flex;
		flex-direction: column;
		width: 100%;
		min-height: 35rem;
		padding: 0.9rem;
		border: 0.18rem solid var(--color-border-paper);
		background: var(--color-surface-paper-raised);
		box-shadow: var(--shadow-paper-rest);
		transform: rotate(-0.35deg);
		transition:
			box-shadow 200ms ease,
			transform 200ms ease;
	}

	.project-frame::before {
		content: "";
		position: absolute;
		top: 0;
		left: 50%;
		width: var(--size-project-tape-width);
		height: var(--size-project-tape-height);
		transform: translate(-50%, -50%) rotate(1.2deg);
		background: var(--color-tape);
		pointer-events: none;
		z-index: 1;
	}

	.project-card:hover .project-frame,
	.project-card:focus-within .project-frame {
		box-shadow: var(--shadow-paper-hover);
		transform: translateY(-4px) rotate(-0.35deg);
	}

	.project-card:hover :global(.project-title-highlight)::before,
	.project-card:focus-within :global(.project-title-highlight)::before {
		transform: var(
			--highlight-transform-active,
			scaleX(1) skewX(-4deg) rotate(-1.2deg)
		);
		opacity: 1;
	}

	.preview {
		width: 100%;
		aspect-ratio: 16 / 9;
		min-height: 17.25rem;
		background: var(--color-media-fallback);
		overflow: hidden;
	}

	.preview-image {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	:global(.project-title-highlight) {
		margin: 0;
		font-family: var(--font-handwriting);
		font-size: var(--type-hand-size-title-md);
		font-weight: 700;
		line-height: 0.5;
		color: var(--color-text-handwriting);
		--highlight-color: var(--color-highlight-yellow-strong);
		--highlight-top: -0.1em;
		--highlight-bottom: -0.1em;
		--highlight-left: -0.04em;
		--highlight-right: -0.03em;
	}

	.project-subtitle {
		font-family: var(--font-handwriting);
		font-size: var(--type-hand-size-label);
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--color-text-muted);
	}

	.project-meta p {
		margin: 0;
		font-family: var(--font-sans);
		font-size: var(--type-sans-size-body);
		font-weight: var(--type-sans-weight-regular);
		line-height: 1.45;
		color: var(--color-text-muted);
	}

	.project-meta :global(.tool-badges) {
		gap: 0.45rem;
		padding-top: 1.2rem;
	}

	.project-meta :global(.tool-badge-shape) {
		background: var(--color-surface-overlay);
		box-shadow: var(--shadow-badge-rest);
	}

	.hero-note {
		margin: 0;
		font-family: var(--font-handwriting);
		color: var(--color-text-handwriting);
		font-size: var(--type-hand-size-body);
		text-align: center;
	}

	@media (max-width: 640px) {
		h1 {
			font-size: var(--type-hand-size-display-lg);
			max-width: 10ch;
		}

		h2 {
			font-size: var(--type-hand-size-display-sm);
			max-width: 15ch;
		}

		.hero-actions :global(.imperfect-button) {
			width: 100%;
			min-height: 3rem;
			padding: 1rem 1rem;
			font-size: 1.5rem;
		}

		.hero-actions :global(.imperfect-button > span) {
			line-height: 1.05;
		}

		.hero-note {
			font-size: 1rem;
			text-wrap: balance;
		}

		.project-frame {
			min-height: auto;
			transform: none;
		}

		.project-card:hover .project-frame,
		.project-card:focus-within .project-frame {
			transform: translateY(-4px);
		}
	}
</style>
