---
import DefaultLayout from "../layouts/DefaultLayout.astro";
import HighlightText from "../components/ui/HighlightText.astro";
import ToolBadges from "../components/ui/ToolBadges.astro";
import { frontmatter as horus } from "../content/horus/00-intro.md";
import { frontmatter as sprout } from "../content/sprout/00-intro.md";
import { frontmatter as checkit } from "../content/checkit/00-intro.md";

type ProjectFrontmatter = {
	title: string;
	project: string;
	description: string;
	tools?: string[];
};

const projects: Array<{
	slug: string;
	frontmatter: ProjectFrontmatter;
}> = [
	{
		slug: "horus",
		frontmatter: horus as ProjectFrontmatter,
	},
	{
		slug: "sprout",
		frontmatter: sprout as ProjectFrontmatter,
	},
	{
		slug: "checkit",
		frontmatter: checkit as ProjectFrontmatter,
	},
];
---

<DefaultLayout title="Projects">
	<h1>These are my projects</h1>
	<div class="projects-layout">
		{
			projects.map(({ slug, frontmatter }) => (
				<a
					class="project-card"
					href={`/projects/${slug}`}
					aria-label={`Open ${frontmatter.title} project page`}>
					<div class="project-frame">
						<div
							class="preview"
							aria-hidden="true"
						/>
						<div class="project-meta">
							<ToolBadges
								tools={frontmatter.tools ?? []}
								projectTitle={frontmatter.title}
							/>
							<div class="project-title">
								<HighlightText
									tag="h2"
									variant="yellow"
									class="project-title-highlight">
									{frontmatter.title}
								</HighlightText>
								<span>{frontmatter.project}</span>
							</div>
							<p>{frontmatter.description}</p>
						</div>
					</div>
				</a>
			))
		}
	</div>
</DefaultLayout>

<style>
	h1 {
		font-size: clamp(2.25rem, 9vw, 5rem);
		font-weight: 700;
		margin-bottom: clamp(1.75rem, 4vw, 3rem);
	}

	.projects-layout {
		display: grid;
		grid-template-columns: repeat(12, minmax(0, 1fr));
		gap: clamp(1rem, 2.5vw, 2rem);
	}

	.project-card {
		display: flex;
		flex-direction: column;
		grid-column: span 6;
		color: var(--color-text-body);
		text-decoration: none;
	}

	.project-frame {
		display: flex;
		flex-direction: column;
		height: 100%;
		padding: clamp(0.95rem, 2vw, 1.3rem);
		border: 0.18rem solid rgba(31, 30, 25, 0.08);
		background: linear-gradient(
			180deg,
			rgba(255, 255, 255, 0.96),
			rgba(247, 242, 231, 0.96)
		);
		box-shadow: 6px 7px 3px rgba(54, 43, 21, 0.14);
		transform: rotate(var(--preview-tilt, 0deg));
		transition:
			box-shadow 200ms ease,
			transform 200ms ease;
	}

	.project-card:nth-of-type(odd) {
		--preview-tilt: -0.45deg;
	}

	.project-card:nth-of-type(even) {
		--preview-tilt: 0.45deg;
	}

	.project-card:hover .project-frame,
	.project-card:focus-within .project-frame {
		box-shadow: 8px 10px 4px rgba(54, 43, 21, 0.24);
		transform: translateY(-4px) rotate(var(--preview-tilt, 0deg));
	}

	.project-card:hover :global(.project-title-highlight)::before,
	.project-card:focus-within :global(.project-title-highlight)::before {
		transform: var(
			--highlight-transform-active,
			scaleX(1) skewX(-4deg) rotate(-1.2deg)
		);
		opacity: 1;
	}

	.preview {
		width: 100%;
		min-height: clamp(15rem, 38vh, 22rem);
		background: var(--color-accent-lime);
		overflow: hidden;
	}

	.project-meta {
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
		padding: clamp(1rem, 2.2vw, 1.35rem) 0 0.15rem;
	}

	.project-title {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.35rem;
	}

	:global(.project-title-highlight) {
		margin: 0;
		font-size: clamp(1.7rem, 2.7vw, 2.7rem);
		font-weight: 700;
		line-height: 0.95;
		color: var(--color-text-heading);
		--highlight-colour: var(--color-highlight-yellow-strong);
		--highlight-top: 0.18em;
		--highlight-bottom: 0.06em;
		--highlight-left: -0.04em;
		--highlight-right: -0.03em;
	}

	.project-title span {
		font-family: var(--font-handwriting);
		font-size: clamp(1.1rem, 1.2vw + 0.8rem, 1.45rem);
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--color-text-muted);
	}

	.project-meta p {
		margin: 0;
		font-family: var(--font-sans);
		font-size: var(--type-sans-size-body);
		font-weight: var(--type-sans-weight-regular);
		line-height: var(--type-sans-leading-compact);
		color: var(--color-text-muted);
	}

	.project-meta :global(.tool-badges) {
		gap: 0.45rem;
	}

	.project-meta :global(.tool-badge-shape) {
		background: rgba(255, 255, 255, 0.9);
		box-shadow: 0 3px 6px rgba(54, 43, 21, 0.08);
	}

	@media (max-width: 900px) {
		.project-card {
			grid-column: 1 / -1;
		}
	}

	@media (max-width: 640px) {
		.preview {
			min-height: auto;
			aspect-ratio: 16 / 9;
		}

		.project-meta p {
			font-size: 0.95rem;
		}

		.project-frame {
			transform: none;
		}

		.project-card:hover .project-frame,
		.project-card:focus-within .project-frame {
			transform: translateY(-4px);
		}
	}
</style>
