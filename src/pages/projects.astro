---
import DefaultLayout from "../layouts/DefaultLayout.astro";
---

<DefaultLayout title="Projects">
	<h1>These are my projects</h1>
	<div class="projects-layout">
		<a
			class="project-card project-big"
			href="/projects/horus"
			aria-label="Open Horus project page">
			<div class="preview preview-big"></div>
			<h2>Horus</h2>
			<span>Full Stack Web App</span>
		</a>
		<a
			class="project-card project-small"
			href="/projects/sprout"
			aria-label="Open Sprout project page">
			<div class="preview preview-small"></div>
			<h2>Sprout</h2>
			<span>App UX Design</span>
		</a>
		<a
			class="project-card project-small"
			href="/projects/checkit"
			aria-label="Open Check It project page">
			<div class="preview preview-small"></div>
			<h2>Check It</h2>
			<span>App UX Design</span>
		</a>
	</div>
</DefaultLayout>

<style>
	:root {
		--project-text: rgb(50 50 50);
	}

	h1 {
		font-size: clamp(2.25rem, 9vw, 5rem);
		font-weight: 700;
		margin-bottom: clamp(1.75rem, 4vw, 3rem);
	}

	.projects-layout {
		display: grid;
		grid-template-columns: repeat(12, minmax(0, 1fr));
		gap: clamp(1rem, 2.5vw, 2rem);
	}

	.project-card {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		padding: clamp(0.9rem, 2vw, 1.25rem);
		color: var(--project-text);
		text-decoration: none;
	}

	.project-card:nth-of-type(odd) {
		--preview-tilt: -0.45deg;
	}

	.project-card:nth-of-type(even) {
		--preview-tilt: 0.45deg;
	}

	.project-big {
		grid-column: 1 / -1;
	}

	.project-small {
		grid-column: span 6;
	}

	.project-card h2 {
		font-size: clamp(1.25rem, 2.5vw, 2rem);
		line-height: 1.1;
	}

	.project-card span {
		font-size: 0.92rem;
		letter-spacing: 0.04em;
		color: rgb(15 23 42 / 0.72);
	}

	.preview {
		width: 100%;
		border: 8px solid rgb(255 255 255 / 1);
		background: rgb(190 242 100);
		box-shadow: 0 8px 20px rgb(15 23 42 / 0.15);
		transform: rotate(var(--preview-tilt, 0deg));
		transition: box-shadow 180ms ease, transform 180ms ease;
	}

	.project-card:hover .preview,
	.project-card:focus-within .preview {
		box-shadow: 0 10px 22px rgb(15 23 42 / 0.3);
		transform: translateY(-2px) rotate(var(--preview-tilt, 0deg));
	}

	.preview-big {
		min-height: clamp(16rem, 46vh, 30rem);
	}

	.preview-small {
		min-height: clamp(12rem, 36vh, 22rem);
	}

	@media (max-width: 900px) {
		.project-small {
			grid-column: 1 / -1;
		}
	}
</style>
