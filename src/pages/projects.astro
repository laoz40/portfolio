---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import DefaultLayout from "../layouts/DefaultLayout.astro";
import ImperfectButton from "../components/home/ImperfectButton.astro";
import HighlightText from "../components/ui/HighlightText.astro";
import ToolBadges from "../components/ui/ToolBadges.astro";
import { getEntry } from "astro:content";

type ProjectFrontmatter = {
	title: string;
	project: string;
	description: string;
	tools?: string[];
	coverImage?: ImageMetadata;
	altText?: string;
};

const projectSlugs = ["horus", "sprout", "checkit", "vvstudios"] as const;
const disabledProjectSlugs = new Set<(typeof projectSlugs)[number]>([
	"vvstudios",
]);

const projectEntries = await Promise.all(
	projectSlugs.map(async (slug) => ({
		slug,
		entry: await getEntry(slug, "00-intro"),
	})),
);

const missingProjects = projectEntries
	.filter(({ entry }) => !entry)
	.map(({ slug }) => slug);

if (missingProjects.length > 0) {
	throw new Error(`Missing intro entry for: ${missingProjects.join(", ")}`);
}

const projects: Array<{
	slug: (typeof projectSlugs)[number];
	frontmatter: ProjectFrontmatter;
}> = projectEntries.map(({ slug, entry }) => ({
	slug,
	frontmatter: entry!.data as ProjectFrontmatter,
}));
---

<DefaultLayout title="Projects">
	<h1>These are my projects</h1>
	<div
		class="projects-layout grid [grid-template-columns:repeat(2,minmax(0,29.75rem))] justify-center gap-x-12 gap-y-8 max-[900px]:grid-cols-[minmax(0,1fr)] max-[900px]:justify-stretch max-[900px]:gap-7 min-[1440px]:[grid-template-columns:repeat(2,minmax(0,42.5rem))] min-[1440px]:gap-x-10">
		{
			projects.map(({ slug, frontmatter }) => {
				const isDisabled = disabledProjectSlugs.has(slug);
				const cardContent = (
					<div class="project-frame">
						<div
							class="preview"
							aria-hidden="true">
							{frontmatter.coverImage ? (
								<Image
									class="preview-image"
									src={frontmatter.coverImage}
									alt={frontmatter.altText}
									loading="lazy"
									decoding="async"
								/>
							) : (
								<span class="preview-placeholder">COMING SOON</span>
							)}
						</div>
						<div class="project-meta flex flex-1 flex-col justify-between px-0 pt-4 pb-[0.1rem] min-[1440px]:justify-start min-[1440px]:gap-4">
							<div class="flex flex-col gap-[0.7rem]">
								<div class="project-title flex flex-col items-start gap-[0.35rem]">
									<HighlightText
										tag="h2"
										variant="yellow"
										class="project-title-highlight">
										{frontmatter.title}
									</HighlightText>
									<span class="project-subtitle">{frontmatter.project}</span>
								</div>
								<p>{frontmatter.description}</p>
							</div>
							<ToolBadges
								tools={frontmatter.tools ?? []}
								projectTitle={frontmatter.title}
							/>
						</div>
					</div>
				);

				if (isDisabled) {
					return (
						<div
							class="project-card project-card-disabled"
							aria-disabled="true">
							{cardContent}
						</div>
					);
				}

				return (
					<a
						class="project-card"
						href={`/projects/${slug}`}
						aria-label={`Open ${frontmatter.title} project page`}>
						{cardContent}
					</a>
				);
			})
		}
	</div>
	<div class="mt-10 flex justify-center">
		<ImperfectButton
			href="/about"
			fill="var(--color-home-button-sky)">
			Read about me
		</ImperfectButton>
	</div>
</DefaultLayout>

<style>
	h1 {
		margin: 0 0 2.5rem;
		font-size: var(--type-hand-size-display-md);
		font-weight: 700;
		text-align: center;
	}

	.project-card {
		display: flex;
		flex-direction: column;
		width: 100%;
		color: var(--color-text-body);
		text-decoration: none;
	}

	.project-card-disabled {
		cursor: default;
	}

	.project-frame {
		position: relative;
		display: flex;
		flex-direction: column;
		height: 100%;
		min-height: 35rem;
		padding: 0.9rem;
		border: 0.18rem solid var(--color-border-paper);
		background: var(--color-surface-paper-solid);
		box-shadow: var(--shadow-paper-rest);
		transform: rotate(var(--preview-tilt, 0deg));
		transition:
			box-shadow 200ms ease,
			transform 200ms ease;
	}

	.project-frame::before {
		content: "";
		position: absolute;
		top: 0;
		left: 50%;
		width: var(--size-project-tape-width);
		height: var(--size-project-tape-height);
		transform: translate(-50%, -50%) rotate(1.2deg);
		background: var(--color-tape);
		pointer-events: none;
		z-index: 1;
	}

	.project-card:nth-of-type(odd) {
		--preview-tilt: -0.45deg;
	}

	.project-card:nth-of-type(even) {
		--preview-tilt: 0.45deg;
	}

	.project-card:hover .project-frame,
	.project-card:focus-within .project-frame {
		box-shadow: var(--shadow-paper-hover);
		transform: translateY(-4px) rotate(var(--preview-tilt, 0deg));
	}

	.project-card:hover :global(.project-title-highlight)::before,
	.project-card:focus-within :global(.project-title-highlight)::before {
		transform: var(
			--highlight-transform-active,
			scaleX(1) skewX(-4deg) rotate(-1.2deg)
		);
		opacity: 1;
	}

	.preview {
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		width: 100%;
		aspect-ratio: 16 / 9;
		background: var(--color-surface-paper-solid);
		overflow: hidden;
	}

	.preview-placeholder {
		font-size: 3rem;
		font-weight: 700;
		font-family: var(--font-handwriting);
	}

	.preview-image {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	:global(.project-title-highlight) {
		margin: 0;
		font-family: var(--font-handwriting);
		font-size: var(--type-hand-size-title-md);
		font-weight: 700;
		line-height: 0.95;
		color: var(--color-text-handwriting);
		--highlight-color: var(--color-highlight-yellow-strong);
		--highlight-top: 0.1em;
		--highlight-bottom: 0.1em;
		--highlight-left: -0.04em;
		--highlight-right: -0.03em;
	}

	.project-subtitle {
		font-family: var(--font-handwriting);
		font-size: var(--type-hand-size-label);
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--color-text-muted);
	}

	.project-meta p {
		margin: 0;
		font-family: var(--font-sans);
		font-size: var(--type-sans-size-body-sm);
		font-weight: var(--type-sans-weight-regular);
		line-height: 1.45;
		color: var(--color-text-muted);
	}

	.project-meta :global(.tool-badges) {
		gap: 0.45rem;
		padding-top: 1.2rem;
	}

	.project-meta :global(.tool-badge-shape) {
		background: var(--color-surface-paper);
		box-shadow: var(--shadow-badge-rest);
	}

	@media (max-width: 900px) {
		.project-frame {
			min-height: auto;
			padding: 0.95rem;
		}

		.project-card {
			width: 100%;
		}
	}

	@media (max-width: 640px) {
		.project-meta p {
			font-size: 0.95rem;
		}

		.project-frame {
			transform: none;
		}

		.project-card:hover .project-frame,
		.project-card:focus-within .project-frame {
			transform: translateY(-4px);
		}
	}

	@media (min-width: 1440px) {
		.project-frame {
			min-height: 39rem;
		}

		.project-meta :global(.tool-badges) {
			margin-top: auto;
			padding-top: 1.25rem;
		}
	}
</style>
