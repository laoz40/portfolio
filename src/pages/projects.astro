---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import DefaultLayout from "../layouts/DefaultLayout.astro";
import HighlightText from "../components/ui/HighlightText.astro";
import ToolBadges from "../components/ui/ToolBadges.astro";
import { getEntry } from "astro:content";

type ProjectFrontmatter = {
	title: string;
	project: string;
	description: string;
	tools?: string[];
	coverImage?: ImageMetadata;
	altText?: string;
};

const projectSlugs = ["horus", "sprout", "checkit", "vvstudios"] as const;

const projectEntries = await Promise.all(
	projectSlugs.map(async (slug) => ({
		slug,
		entry: await getEntry(slug, "00-intro"),
	})),
);

const missingProjects = projectEntries
	.filter(({ entry }) => !entry)
	.map(({ slug }) => slug);

if (missingProjects.length > 0) {
	throw new Error(`Missing intro entry for: ${missingProjects.join(", ")}`);
}

const projects: Array<{
	slug: (typeof projectSlugs)[number];
	frontmatter: ProjectFrontmatter;
}> = projectEntries.map(({ slug, entry }) => ({
	slug,
	frontmatter: entry!.data as ProjectFrontmatter,
}));
---

<DefaultLayout title="Projects">
	<h1>These are my projects</h1>
	<div class="projects-layout">
		{
			projects.map(({ slug, frontmatter }) => {
				return (
					<a
						class="project-card"
						href={`/projects/${slug}`}
						aria-label={`Open ${frontmatter.title} project page`}>
						<div class="project-frame">
							<div
								class="preview"
								aria-hidden="true">
								{frontmatter.coverImage ? (
									<Image
										class="preview-image"
										src={frontmatter.coverImage}
										alt={frontmatter.altText}
										loading="lazy"
										decoding="async"
									/>
								) : (
									<span>COMING SOON</span>
								)}
							</div>
							<div class="project-meta">
								<div class="project-copy">
									<div class="project-title">
										<HighlightText
											tag="h2"
											variant="yellow"
											class="project-title-highlight">
											{frontmatter.title}
										</HighlightText>
										<span>{frontmatter.project}</span>
									</div>
									<p>{frontmatter.description}</p>
								</div>
								<ToolBadges
									tools={frontmatter.tools ?? []}
									projectTitle={frontmatter.title}
								/>
							</div>
						</div>
					</a>
				);
			})
		}
	</div>
</DefaultLayout>

<style>
	h1 {
		font-size: clamp(1.9rem, 5vw, 3.5rem);
		font-weight: 700;
		text-align: center;
		margin-bottom: clamp(1.75rem, 4vw, 3rem);
	}

	.projects-layout {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 29.75rem));
		justify-content: center;
		column-gap: clamp(2rem, 5vw, 4.5rem);
		row-gap: clamp(1.75rem, 3vw, 3rem);
	}

	.project-card {
		display: flex;
		flex-direction: column;
		width: 100%;
		color: var(--color-text-body);
		text-decoration: none;
	}

	.project-frame {
		position: relative;
		display: flex;
		flex-direction: column;
		height: 100%;
		min-height: clamp(33rem, 38vw, 36rem);
		padding: clamp(0.75rem, 1.1vw, 0.95rem);
		border: 0.18rem solid rgba(31, 30, 25, 0.08);
		background: rgba(250, 247, 240, 1);
		box-shadow: var(--shadow-paper-rest);
		transform: rotate(var(--preview-tilt, 0deg));
		transition:
			box-shadow 200ms ease,
			transform 200ms ease;
	}

	.project-frame::before {
		content: "";
		position: absolute;
		top: 0;
		left: 50%;
		width: var(--size-project-tape-width);
		height: var(--size-project-tape-height);
		transform: translate(-50%, -50%) rotate(1.2deg);
		background: var(--color-tape);
		pointer-events: none;
		z-index: 1;
	}

	.project-card:nth-of-type(odd) {
		--preview-tilt: -0.45deg;
	}

	.project-card:nth-of-type(even) {
		--preview-tilt: 0.45deg;
	}

	.project-card:hover .project-frame,
	.project-card:focus-within .project-frame {
		box-shadow: var(--shadow-paper-hover);
		transform: translateY(-4px) rotate(var(--preview-tilt, 0deg));
	}

	.project-card:hover :global(.project-title-highlight)::before,
	.project-card:focus-within :global(.project-title-highlight)::before {
		transform: var(
			--highlight-transform-active,
			scaleX(1) skewX(-4deg) rotate(-1.2deg)
		);
		opacity: 1;
	}

	.preview {
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		width: 100%;
		aspect-ratio: 16 / 9;
		background: rgba(250, 247, 240, 1);
		overflow: hidden;
	}

	.preview span {
		font-size: 2rem;
		font-weight: 700;
		color: var(--color-text-muted);
	}

	.preview-image {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.project-meta {
		display: flex;
		flex-direction: column;
		flex: 1;
		justify-content: space-between;
		padding: clamp(0.75rem, 1.15vw, 0.95rem) 0 0.1rem;
	}

	.project-copy {
		display: flex;
		flex-direction: column;
		gap: 0.7rem;
	}

	.project-title {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.35rem;
	}

	:global(.project-title-highlight) {
		margin: 0;
		font-size: clamp(1.55rem, 1.2vw + 1.1rem, 2.15rem);
		font-weight: 700;
		line-height: 0.95;
		color: var(--color-text-heading);
		--highlight-colour: var(--color-highlight-yellow-strong);
		--highlight-top: 0.1em;
		--highlight-bottom: 0.1em;
		--highlight-left: -0.04em;
		--highlight-right: -0.03em;
	}

	.project-title span {
		font-family: var(--font-handwriting);
		font-size: clamp(1rem, 0.7vw + 0.85rem, 1.25rem);
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--color-text-muted);
	}

	.project-meta p {
		margin: 0;
		font-family: var(--font-sans);
		font-size: clamp(0.92rem, 0.35vw + 0.82rem, 0.99rem);
		font-weight: var(--type-sans-weight-regular);
		line-height: 1.45;
		color: var(--color-text-muted);
	}

	.project-meta :global(.tool-badges) {
		gap: 0.45rem;
		padding-top: clamp(0.9rem, 1.8vw, 1.5rem);
	}

	.project-meta :global(.tool-badge-shape) {
		background: var(--color-surface-paper);
		box-shadow: 0 3px 6px rgba(54, 43, 21, 0.08);
	}

	@media (max-width: 900px) {
		.projects-layout {
			grid-template-columns: minmax(0, 1fr);
			justify-content: stretch;
			gap: 1.75rem;
		}

		.project-frame {
			min-height: auto;
			padding: clamp(0.85rem, 1.8vw, 1rem);
		}

		.project-card {
			width: 100%;
		}
	}

	@media (max-width: 640px) {
		.project-meta p {
			font-size: 0.95rem;
		}

		.project-frame {
			transform: none;
		}

		.project-card:hover .project-frame,
		.project-card:focus-within .project-frame {
			transform: translateY(-4px);
		}
	}

	@media (min-width: 1440px) {
		.projects-layout {
			grid-template-columns: repeat(2, minmax(0, 42.5rem));
			column-gap: clamp(1.75rem, 2.4vw, 3.25rem);
		}

		.project-frame {
			min-height: clamp(38rem, 34vw, 40.5rem);
		}

		.project-meta {
			justify-content: flex-start;
			gap: clamp(0.9rem, 0.9vw, 1.2rem);
		}

		.project-meta :global(.tool-badges) {
			margin-top: auto;
			padding-top: clamp(1rem, 1.1vw, 1.35rem);
		}
	}
</style>
