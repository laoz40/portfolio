---
import DefaultLayout from "../layouts/DefaultLayout.astro";
import HighlightText from "../components/HighlightText.astro";
import { frontmatter as horus } from "../content/horus/00-intro.md";
import { frontmatter as sprout } from "../content/sprout/00-intro.md";
import { frontmatter as checkit } from "../content/checkit/00-intro.md";
---

<DefaultLayout title="Projects">
	<h1>These are my projects</h1>
	<div class="projects-layout">
		<a
			class="project-card project-big"
			href="/projects/horus"
			aria-label={`Open ${horus.title} project page`}>
			<div class="preview preview-big"></div>
			<ul
				class="tool-badges"
				aria-label={`${horus.title} tools used`}>
				{(horus.tools ?? []).map((tool) => <li class="tool-badge">{tool}</li>)}
			</ul>
			<div class="project-title">
				<HighlightText
					tag="h2"
					variant="yellow"
					class="project-title-highlight">
					{horus.title}
				</HighlightText>
				<span>{horus.project}</span>
			</div>
			<p>{horus.description}</p>
		</a>
		<a
			class="project-card project-small"
			href="/projects/sprout"
			aria-label={`Open ${sprout.title} project page`}>
			<div class="preview preview-small"></div>
			<ul
				class="tool-badges"
				aria-label={`${sprout.title} tools used`}>
				{(sprout.tools ?? []).map((tool) => <li class="tool-badge">{tool}</li>)}
			</ul>
			<div class="project-title">
				<HighlightText
					tag="h2"
					variant="yellow"
					class="project-title-highlight">
					{sprout.title}
				</HighlightText>
				<span>{sprout.project}</span>
			</div>
			<p>{sprout.description}</p>
		</a>
		<a
			class="project-card project-small"
			href="/projects/checkit"
			aria-label={`Open ${checkit.title} project page`}>
			<div class="preview preview-small"></div>
			<ul
				class="tool-badges"
				aria-label={`${checkit.title} tools used`}>
				{
					(checkit.tools ?? []).map((tool) => (
						<li class="tool-badge">{tool}</li>
					))
				}
			</ul>
			<div class="project-title">
				<HighlightText
					tag="h2"
					variant="yellow"
					class="project-title-highlight">
					{checkit.title}
				</HighlightText>
				<span>{checkit.project}</span>
			</div>
			<p>{checkit.description}</p>
		</a>
	</div>
</DefaultLayout>

<style>
	:root {
		--project-text: rgb(50 50 50);
	}

	h1 {
		font-size: clamp(2.25rem, 9vw, 5rem);
		font-weight: 700;
		margin-bottom: clamp(1.75rem, 4vw, 3rem);
	}

	.projects-layout {
		display: grid;
		grid-template-columns: repeat(12, minmax(0, 1fr));
		gap: clamp(1rem, 2.5vw, 2rem);
	}

	.project-card {
		display: flex;
		flex-direction: column;
		padding: clamp(0.9rem, 2vw, 1.25rem);
		color: var(--project-text);
		text-decoration: none;
	}

	.project-title {
		display: flex;
		justify-content: start;
		gap: 1rem;
		align-items: baseline;
		margin: 1rem 0 0 0;
	}

	.project-card:nth-of-type(odd) {
		--preview-tilt: -0.45deg;
	}

	.project-card:nth-of-type(even) {
		--preview-tilt: 0.45deg;
	}

	.project-big {
		grid-column: 1 / -1;
	}

	.project-small {
		grid-column: span 6;
	}

	:global(.project-title-highlight) {
		font-size: clamp(1.5rem, 2.5vw, 2.5rem);
		font-weight: 700;
		--highlight-colour: rgb(255 230 0 / 0.75);
		--highlight-top: 0.3em;
		--highlight-bottom: 0.32em;
	}

	.project-card:hover :global(.project-title-highlight)::before,
	.project-card:focus-within :global(.project-title-highlight)::before {
		transform: var(
			--highlight-transform-active,
			scaleX(1) skewX(-4deg) rotate(-1.2deg)
		);
		opacity: 1;
	}

	.project-card span {
		font-size: clamp(1rem, 2vw, 1.5rem);
		letter-spacing: 0.02em;
	}

	.project-card p {
		margin: 0;
		/* font-size: clamp(1rem, 2vw, 1.5rem); */
		font-family: var(--font-sans);
		font-size: clamp(1.08rem, 0.3vw + 1rem, 1.2rem);
		font-weight: 300;
		line-height: 1.25;
		color: rgb(15 23 42 / 0.82);
	}

	.tool-badges {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 1.5rem 0 0 0;
		padding: 0;
		list-style: none;
	}

	.tool-badge {
		padding: 0.1rem 0.65rem;
		border: 1px solid rgb(15 23 42 / 0.2);
		font-size: clamp(0.75rem, 1vw, 1.25rem);
		font-weight: 700;
		/* font-family: var(--font-sans); */
		/* font-size: 1rem */
		letter-spacing: 0.02em;
		color: rgb(15 23 42 / 0.85);
		background: rgb(255 255 255 / 0.45);
		box-shadow: 0 1px 3px rgb(15 23 42 / 0.12);
	}

	.preview {
		width: 100%;
		border: 8px solid rgb(255 255 255 / 1);
		background: rgb(190 242 100);
		box-shadow: 0 8px 20px rgb(15 23 42 / 0.15);
		transform: rotate(var(--preview-tilt, 0deg));
		transition:
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.project-card:hover .preview,
	.project-card:focus-within .preview {
		box-shadow: 0 10px 22px rgb(15 23 42 / 0.3);
		transform: translateY(-2px) rotate(var(--preview-tilt, 0deg));
	}

	.preview-big {
		min-height: clamp(16rem, 46vh, 30rem);
	}

	.preview-small {
		min-height: clamp(12rem, 36vh, 22rem);
	}

	@media (max-width: 900px) {
		.project-small {
			grid-column: 1 / -1;
		}
	}
</style>
