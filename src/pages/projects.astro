---
import DefaultLayout from "../layouts/DefaultLayout.astro";
import HighlightText from "../components/ui/HighlightText.astro";
import { frontmatter as horus } from "../content/horus/00-intro.md";
import { frontmatter as sprout } from "../content/sprout/00-intro.md";
import { frontmatter as checkit } from "../content/checkit/00-intro.md";

type ProjectFrontmatter = {
	title: string;
	project: string;
	description: string;
	tools?: string[];
};

const projects: Array<{
	slug: string;
	layoutClass: "project-big" | "project-small";
	frontmatter: ProjectFrontmatter;
}> = [
	{
		slug: "horus",
		layoutClass: "project-big",
		frontmatter: horus as ProjectFrontmatter,
	},
	{
		slug: "sprout",
		layoutClass: "project-small",
		frontmatter: sprout as ProjectFrontmatter,
	},
	{
		slug: "checkit",
		layoutClass: "project-small",
		frontmatter: checkit as ProjectFrontmatter,
	},
];
---

<DefaultLayout title="Projects">
	<h1>These are my projects</h1>
	<div class="projects-layout">
		{
			projects.map(({ slug, layoutClass, frontmatter }) => (
				<a
					class:list={["project-card", layoutClass]}
					href={`/projects/${slug}`}
					aria-label={`Open ${frontmatter.title} project page`}>
					<div
						class:list={[
							"preview",
							layoutClass === "project-big" ? "preview-big" : "preview-small",
						]}
					/>
					<ul
						class="tool-badges"
						aria-label={`${frontmatter.title} tools used`}>
						{(frontmatter.tools ?? []).map((tool) => (
							<li class="tool-badge">{tool}</li>
						))}
					</ul>
					<div class="project-title">
						<HighlightText
							tag="h2"
							variant="yellow"
							class="project-title-highlight">
							{frontmatter.title}
						</HighlightText>
						<span>{frontmatter.project}</span>
					</div>
					<p>{frontmatter.description}</p>
				</a>
			))
		}
	</div>
</DefaultLayout>

<style>
	h1 {
		font-size: clamp(2.25rem, 9vw, 5rem);
		font-weight: 700;
		margin-bottom: clamp(1.75rem, 4vw, 3rem);
	}

	.projects-layout {
		display: grid;
		grid-template-columns: repeat(12, minmax(0, 1fr));
		gap: clamp(1rem, 2.5vw, 2rem);
	}

	.project-card {
		display: flex;
		flex-direction: column;
		padding: clamp(0.9rem, 2vw, 1.25rem);
		color: var(--color-text-body);
		text-decoration: none;
	}

	.project-title {
		display: flex;
		justify-content: start;
		gap: 1rem;
		align-items: baseline;
		margin: 1rem 0 0 0;
	}

	.project-card:nth-of-type(odd) {
		--preview-tilt: -0.45deg;
	}

	.project-card:nth-of-type(even) {
		--preview-tilt: 0.45deg;
	}

	.project-big {
		grid-column: 1 / -1;
	}

	.project-small {
		grid-column: span 6;
	}

	:global(.project-title-highlight) {
		font-size: clamp(1.5rem, 2.5vw, 2.5rem);
		font-weight: 700;
		--highlight-colour: var(--color-highlight-yellow-strong);
		--highlight-top: 0.3em;
		--highlight-bottom: 0.32em;
	}

	.project-card:hover :global(.project-title-highlight)::before,
	.project-card:focus-within :global(.project-title-highlight)::before {
		transform: var(
			--highlight-transform-active,
			scaleX(1) skewX(-4deg) rotate(-1.2deg)
		);
		opacity: 1;
	}

	.project-card span {
		font-size: clamp(1rem, 2vw, 1.5rem);
		letter-spacing: 0.02em;
	}

	.project-card p {
		margin: 0;
		font-family: var(--font-sans);
		font-size: var(--type-sans-size-body);
		font-weight: var(--type-sans-weight-regular);
		line-height: var(--type-sans-leading-compact);
		color: var(--color-text-muted);
	}

	.tool-badges {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 1.5rem 0 0 0;
		padding: 0;
		list-style: none;
	}

	.tool-badge {
		padding: 0.1rem 0.65rem;
		border: 1px solid var(--color-border-soft);
		font-size: clamp(0.75rem, 1vw, 1.25rem);
		font-weight: 700;
		letter-spacing: 0.02em;
		color: var(--color-text-strong);
		background: var(--color-surface-paper-soft);
		box-shadow: 0 1px 3px var(--color-shadow-soft);
	}

	.preview {
		width: 100%;
		border: 8px solid var(--color-surface-paper);
		background: var(--color-accent-lime);
		box-shadow: 0 8px 20px var(--color-shadow-medium);
		transform: rotate(var(--preview-tilt, 0deg));
		transition:
			box-shadow 180ms ease,
			transform 180ms ease;
	}

	.project-card:hover .preview,
	.project-card:focus-within .preview {
		box-shadow: 0 10px 22px var(--color-shadow-strong);
		transform: translateY(-2px) rotate(var(--preview-tilt, 0deg));
	}

	.preview-big {
		min-height: clamp(16rem, 46vh, 30rem);
	}

	.preview-small {
		min-height: clamp(12rem, 36vh, 22rem);
	}

	@media (max-width: 900px) {
		.project-small {
			grid-column: 1 / -1;
		}
	}
</style>
