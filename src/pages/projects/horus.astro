---
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import HorusProjectLinksSection from "../../components/projects/HorusProjectLinksSection.astro";
import ProjectCaseStudy from "../../components/projects/ProjectCaseStudy.astro";
import Intro, { frontmatter } from "../../content/horus/00-intro.md";
import ProjectOverview from "../../content/horus/01-project-overview.md";
import ProjectFeatures from "../../content/horus/02-project-features.md";
import TechStack from "../../content/horus/03-tech-stack.md";

const sections = [
	{ Component: Intro, variant: "featured" },
	{
		Component: HorusProjectLinksSection,
		variant: "contentOnly",
		props: {
			githubUrl: frontmatter.githubUrl,
			websiteUrl: frontmatter.websiteUrl,
		},
	},
	{ Component: ProjectOverview, variant: "contentOnly" },
	{ Component: ProjectFeatures, variant: "contentOnly" },
	{ Component: TechStack, variant: "contentOnly" },
];
---

<DefaultLayout title={frontmatter.title}>
	<ProjectCaseStudy sections={sections} />
</DefaultLayout>
