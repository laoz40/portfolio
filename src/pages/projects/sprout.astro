---
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import IntroContent, { frontmatter } from "../../content/sprout/00-intro.md";
import ProjectOverviewContent from "../../content/sprout/01-project-overview.md";
import ProjectShowcaseContent from "../../content/sprout/02-project-showcase.md";
import ProblemAreaContent from "../../content/sprout/03-problem-area.md";
import OurGoalContent from "../../content/sprout/04-our-goal.md";
import CompetitorAnalysisContent from "../../content/sprout/05-competitor-analysis.md";
import UserResearchMethodsContent from "../../content/sprout/06-user-research-methods.md";
import UserResearchBarriersContent from "../../content/sprout/07-user-research-barriers.md";
import PrototypingContent from "../../content/sprout/08-prototyping.md";
import UserTestingInsightsContent from "../../content/sprout/09-user-testing-insights.md";
import DesignSystemContent from "../../content/sprout/10-design-system.md";
import ReflectionContent from "../../content/sprout/11-reflection.md";
---

<DefaultLayout title={frontmatter.title}>
	<article class="project-content mt-4 flex flex-col gap-12">
		<section class="section-with-media">
			<div class="section-copy"><IntroContent /></div>
			<div
				class="section-media media-lime"
				aria-hidden="true">
			</div>
		</section>
		<section><ProjectOverviewContent /></section>
		<section class="section-with-media">
			<div class="section-copy"><ProjectShowcaseContent /></div>
			<div
				class="section-media media-sky"
				aria-hidden="true">
			</div>
		</section>
		<section class="section-with-media">
			<div class="section-copy"><ProblemAreaContent /></div>
			<div
				class="section-media media-emerald"
				aria-hidden="true">
			</div>
		</section>
		<section><OurGoalContent /></section>
		<section class="section-with-media">
			<div class="section-copy"><CompetitorAnalysisContent /></div>
			<div
				class="section-media media-amber"
				aria-hidden="true">
			</div>
		</section>
		<section class="section-with-media">
			<div class="section-copy"><UserResearchMethodsContent /></div>
			<div
				class="section-media media-cyan"
				aria-hidden="true">
			</div>
		</section>
		<section class="section-with-media section-handwriting-list">
			<div class="section-copy"><UserResearchBarriersContent /></div>
			<div
				class="section-media media-rose"
				aria-hidden="true">
			</div>
		</section>
		<section class="section-with-media">
			<div class="section-copy"><PrototypingContent /></div>
			<div
				class="section-media media-violet"
				aria-hidden="true">
			</div>
		</section>
		<section class="section-with-media">
			<div class="section-copy"><UserTestingInsightsContent /></div>
			<div
				class="section-media media-indigo"
				aria-hidden="true">
			</div>
		</section>
		<section class="section-with-media">
			<div class="section-copy"><DesignSystemContent /></div>
			<div
				class="section-media media-teal"
				aria-hidden="true">
			</div>
		</section>
		<section><ReflectionContent /></section>
	</article>
</DefaultLayout>

<style>
	.section-with-media {
		display: grid;
		grid-template-columns: minmax(0, 1fr) clamp(16rem, 28vw, 24rem);
		gap: clamp(1.25rem, 3vw, 2.5rem);
		align-items: start;
	}

	.section-copy {
		min-width: 0;
	}

	.section-media {
		position: sticky;
		top: clamp(8rem, 22vh, 12.5rem);
		width: 100%;
		min-height: clamp(12rem, 36vh, 22rem);
		border-radius: 1.1rem;
		border: 1px solid rgb(15 23 42 / 0.08);
		box-shadow: 0 18px 40px rgb(15 23 42 / 0.1);
	}

	.media-lime {
		background: linear-gradient(
			145deg,
			rgb(190 242 100 / 0.75),
			rgb(132 204 22 / 0.55)
		);
	}

	.media-sky {
		background: linear-gradient(
			145deg,
			rgb(186 230 253 / 0.75),
			rgb(56 189 248 / 0.55)
		);
	}

	.media-emerald {
		background: linear-gradient(
			145deg,
			rgb(167 243 208 / 0.75),
			rgb(16 185 129 / 0.55)
		);
	}

	.media-amber {
		background: linear-gradient(
			145deg,
			rgb(253 230 138 / 0.78),
			rgb(245 158 11 / 0.52)
		);
	}

	.media-cyan {
		background: linear-gradient(
			145deg,
			rgb(165 243 252 / 0.78),
			rgb(6 182 212 / 0.52)
		);
	}

	.media-rose {
		background: linear-gradient(
			145deg,
			rgb(254 205 211 / 0.8),
			rgb(251 113 133 / 0.5)
		);
	}

	.media-violet {
		background: linear-gradient(
			145deg,
			rgb(221 214 254 / 0.8),
			rgb(139 92 246 / 0.5)
		);
	}

	.media-indigo {
		background: linear-gradient(
			145deg,
			rgb(199 210 254 / 0.8),
			rgb(99 102 241 / 0.5)
		);
	}

	.media-teal {
		background: linear-gradient(
			145deg,
			rgb(153 246 228 / 0.78),
			rgb(20 184 166 / 0.52)
		);
	}

	.project-content {
		--text-measure: 65ch;
		width: min(100%, 78rem);
		margin-inline: auto;
		padding-inline: clamp(0.25rem, 1.5vw, 1rem);
	}

	.project-content :global(h1) {
		font-family: "Leo Handwriting";
		font-size: clamp(3.5rem, 9vw, 7rem);
		font-weight: 700;
		line-height: 0.95;
		margin: 0 0 1rem 0;
		max-width: 12ch;
	}

	.project-content :global(h2) {
		font-family: "Leo Handwriting";
		font-size: clamp(3rem, 5vw, 4rem);
		font-weight: 700;
		line-height: 0.95;
		margin: 2rem 0 2rem 0;
		max-width: 18ch;
	}

	.project-content :global(h3) {
		font-family: "Leo Handwriting";
		font-size: clamp(1.75rem, 3.75vw, 2.75rem);
		margin: 2rem 0 0 0;
		letter-spacing: 0.01em;
		line-height: 1;
		max-width: 32ch;
		text-wrap: balance;
	}

	.project-content :global(h4) {
		font-family: "Outfit Variable";
		font-size: clamp(1.08rem, 0.3vw + 1rem, 1.2rem);
		font-weight: 500;
		color: rgb(50, 50, 50);
		margin: 2rem 0 0.5rem 0;
		letter-spacing: 0.01em;
		line-height: 1.1;
		max-width: 32ch;
	}

	.project-content :global(p) {
		font-family: "Outfit Variable";
		font-size: clamp(1.08rem, 0.3vw + 1rem, 1.2rem);
		font-weight: 400;
		color: rgb(50, 50, 50);
		margin: 0 0 1rem 0;
		line-height: 1.72;
		max-width: var(--text-measure);
		text-wrap: pretty;
	}

	.project-content :global(li) {
		font-family: "Outfit Variable";
		font-size: clamp(1.08rem, 0.3vw + 1rem, 1.2rem);
		font-weight: 400;
		color: rgb(50, 50, 50);
		margin: 0 0 0.35rem 0;
		line-height: 1.55;
		max-width: var(--text-measure);
		text-wrap: pretty;
	}

	.project-content :global(strong),
	.project-content :global(b) {
		font-family: "Outfit Variable";
		font-weight: 500;
		color: rgb(50, 50, 50);
	}

	.project-content :global(ul),
	.project-content :global(ol) {
		padding-left: 1.25rem;
		margin: 0 0 1rem 0;
	}

	.project-content :global(ul) {
		list-style-type: disc;
	}

	.project-content :global(ol) {
		list-style-type: decimal;
	}

	.section-handwriting-list :global(li) {
		font-family: "Leo Handwriting";
		font-size: clamp(1.25rem, 0.5vw + 1rem, 1.5rem);
		color: inherit;
	}

	@media (max-width: 980px) {
		.section-with-media {
			grid-template-columns: 1fr;
			gap: 1rem;
		}

		.section-media {
			position: static;
			min-height: clamp(10rem, 45vw, 14rem);
			width: min(100%, 42rem);
		}
	}

	@media (max-width: 640px) {
		.project-content {
			padding-inline: 0;
		}

		.section-media {
			min-height: 9rem;
			border-radius: 0.9rem;
		}
	}
</style>
