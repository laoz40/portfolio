---
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import ProjectCaseStudy from "../../components/projects/ProjectCaseStudy.astro";
import Intro, { frontmatter } from "../../content/sprout/00-intro.md";
import ProjectOverview from "../../content/sprout/01-project-overview.md";
import ProjectShowcase, {
	frontmatter as projectShowcaseFrontmatter,
} from "../../content/sprout/02-project-showcase.md";
import ProblemArea from "../../content/sprout/03-problem-area.md";
import OurGoal from "../../content/sprout/04-our-goal.md";
import CompetitorAnalysis from "../../content/sprout/05-competitor-analysis.md";
import UserResearchMethods from "../../content/sprout/06-user-research-methods.md";
import UserResearchInsights from "../../content/sprout/07-user-research-barriers.md";
import Prototyping from "../../content/sprout/08-prototyping.md";
import UserTestingInsights, {
	frontmatter as userTestingInsightsFrontmatter,
} from "../../content/sprout/09-user-testing-insights.md";
import DesignSystem from "../../content/sprout/10-design-system.md";
import Reflection from "../../content/sprout/11-reflection.md";

const sections = [
	{ Component: Intro, variant: "featured" },
	{ Component: ProjectOverview, variant: "contentOnly" },
	{
		Component: ProjectShowcase,
		variant: "carousel",
		carouselItems: projectShowcaseFrontmatter.carouselItems,
	},
	{
		Component: ProblemArea,
		variant: "featured",
		media: {
			type: "youtube",
			videoId: "oPx-KKh4q6k",
			title: "Sprout Pitch",
		},
	},
	{ Component: OurGoal, variant: "contentOnly" },
	{ Component: CompetitorAnalysis, variant: "media" },
	{ Component: UserResearchMethods, variant: "media" },
	{
		Component: UserResearchInsights,
		variant: "media",
		extraClass: "section-handwriting-list",
	},
	{ Component: Prototyping, variant: "contentOnly" },
	{
		Component: UserTestingInsights,
		variant: "carousel",
		carouselItems: userTestingInsightsFrontmatter.carouselItems,
	},
	{ Component: DesignSystem, variant: "media" },
	{ Component: Reflection, variant: "contentOnly" },
];
---

<DefaultLayout title={frontmatter.title}>
	<ProjectCaseStudy sections={sections} />
</DefaultLayout>
