---
import ObfuscatedEmailRuntime from "../components/contact/ObfuscatedEmailRuntime.astro";
import ImperfectButton from "../components/home/ImperfectButton.astro";
import DefaultLayout from "../layouts/DefaultLayout.astro";
import { encodeEmailHref } from "../utils/obfuscatedEmail";

type ContactLink = {
	label: string;
	href: string;
	fill: string;
	target: string | undefined;
	rel: string | undefined;
};

const contactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL;
const linkedInUrl = import.meta.env.PUBLIC_LINKEDIN_URL;
const githubUrl = import.meta.env.PUBLIC_GITHUB_URL;

const encodedEmailHref = contactEmail
	? encodeEmailHref(contactEmail)
	: undefined;

const contactLinks = [
	linkedInUrl
		? {
				label: "LinkedIn",
				href: linkedInUrl,
				fill: "var(--color-home-button-sky)",
				target: "_blank",
				rel: "noreferrer",
			}
		: null,
	{
		label: "Resume",
		href: "/resume.pdf",
		fill: "var(--color-button-resume)",
		target: "_blank",
		rel: "noreferrer",
	},
	githubUrl
		? {
				label: "GitHub",
				href: githubUrl,
				fill: "var(--color-button-github)",
				target: "_blank",
				rel: "noreferrer",
			}
		: null,
].filter((link): link is ContactLink => link !== null);
---

<DefaultLayout title="Contact">
	<ObfuscatedEmailRuntime />
	<h1>Here are my links</h1>
	<div
		class="contact-actions mx-auto mt-10 flex w-full max-w-[20rem] flex-col items-center gap-4">
		{
			contactEmail ? (
				<ImperfectButton
					href="#"
					fill="var(--color-home-button-yellow)"
					data-email-link="true"
					data-email-entities={encodedEmailHref}>
					Email
				</ImperfectButton>
			) : null
		}
		{
			contactLinks.map((link) => (
				<ImperfectButton
					href={link.href}
					fill={link.fill}
					target={link.target}
					rel={link.rel}>
					{link.label}
				</ImperfectButton>
			))
		}
	</div>
	<p class="contact-thanks">Thanks for visiting my website :)</p>
</DefaultLayout>

<style>
	h1 {
		margin: 0 0 0.75rem;
		font-size: var(--type-hand-size-display-md);
		font-weight: 700;
		text-align: center;
	}

	.contact-actions :global(.imperfect-button) {
		width: min(100%, 20rem);
	}

	.contact-thanks {
		margin: 2rem auto 0;
		font-family: var(--font-handwriting);
		color: var(--color-text-handwriting);
		text-align: center;
		text-wrap: balance;
		font-size: var(--type-hand-size-title-sm);
	}
</style>
