---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import AboutSectionMedia from "../components/about/AboutSectionMedia.astro";
import ImperfectButton from "../components/home/ImperfectButton.astro";
import DefaultLayout from "../layouts/DefaultLayout.astro";

type AboutImageMedia = Extract<
	NonNullable<CollectionEntry<"about">["data"]["section"]>["media"],
	{ type: "image" }
>;

const aboutEntries = (await getCollection("about")).sort((a, b) => a.id.localeCompare(b.id));

const aboutSections = await Promise.all(
	aboutEntries.map(async (entry) => {
		const { Content } = await render(entry);
		const media = entry.data.section?.media;

		if (media && media.type !== "image") {
			throw new Error(`About entry ${entry.id} uses unsupported media type: ${media.type}`);
		}

		return {
			id: entry.id,
			title: entry.data.title ?? entry.id,
			Content,
			media: media as AboutImageMedia | undefined,
		};
	}),
);
---

<DefaultLayout title="About">
	<section class="about-page">
		<h1>A little bit about me</h1>
		<article
			class="mx-auto mt-6 grid w-full max-w-[78rem] gap-14 max-md:gap-10"
			style="--text-measure: 65ch; --about-media-column-width: 22rem;">
			{
				aboutSections.map(({ id, title, Content, media }, index) => (
					<section
						class:list={[
							"grid items-center gap-10 max-md:gap-7",
							media
								? "md:grid-cols-[minmax(0,1fr)_var(--about-media-column-width)] md:[grid-template-areas:'copy_media']"
								: "grid-cols-[minmax(0,1fr)]",
							media && index % 2 === 1
								? "md:grid-cols-[var(--about-media-column-width)_minmax(0,1fr)] md:[grid-template-areas:'media_copy']"
								: undefined,
						]}
						data-about-section={id}>
						<div class="about-section-copy min-w-0 md:[grid-area:copy]">
							<h2>{title}</h2>
							<Content />
						</div>
						{media ? (
							<div class="about-section-media flex w-full min-w-0 items-center justify-center max-md:justify-start md:[grid-area:media]">
								<AboutSectionMedia media={media} />
							</div>
						) : null}
					</section>
				))
			}
		</article>
		<div
			class="about-actions-reveal mx-auto mt-10 flex w-full max-w-[78rem] flex-col items-center gap-4 text-center">
			<p class="about-actions-note about-actions-note-reveal">
				Thanks for reading all of this! (if you did)
			</p>
			<div class="about-actions-cta-reveal">
				<ImperfectButton
					href="/projects"
					fill="var(--color-home-button-yellow)">
					See my projects
				</ImperfectButton>
			</div>
		</div>
	</section>
</DefaultLayout>

<script>
	import "../animation/aboutAnimations.ts";
</script>

<style>
	h1 {
		margin: 0 auto 1.5rem;
		font-size: var(--type-hand-size-display-md);
		font-weight: 700;
		text-align: center;
		width: min(100%, 78rem);
	}

	h2 {
		font-family: var(--font-handwriting);
		font-size: var(--type-hand-size-title-lg);
		font-weight: 700;
		letter-spacing: 0.01em;
		line-height: 1;
		margin: 0 0 1rem 0;
		max-width: 24ch;
	}

	.about-section-copy :global(p) {
		font-family: var(--font-sans);
		font-size: var(--type-sans-size-body);
		font-weight: var(--type-sans-weight-regular);
		color: var(--color-text-body);
		margin: 0 0 1rem 0;
		line-height: var(--type-sans-leading-reading);
		max-width: var(--text-measure);
		text-wrap: pretty;
	}

	.about-section-copy :global(ul) {
		padding-left: 1.25rem;
		margin: 0 0 1rem 0;
		list-style-type: disc;
	}

	.about-section-copy :global(li) {
		font-family: var(--font-sans);
		font-size: var(--type-sans-size-body);
		font-weight: var(--type-sans-weight-regular);
		color: var(--color-text-body);
		line-height: var(--type-sans-leading-compact);
		max-width: var(--text-measure);
		text-wrap: pretty;
	}

	.about-actions-note {
		margin: 0;
		font-family: var(--font-handwriting);
		font-size: var(--type-hand-size-title-md);
		color: var(--color-text-handwriting);
		font-weight: 400;
		text-wrap: balance;
	}
</style>
