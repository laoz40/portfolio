---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import AboutSectionMedia from "../components/about/AboutSectionMedia.astro";
import ImperfectButton from "../components/home/ImperfectButton.astro";
import DefaultLayout from "../layouts/DefaultLayout.astro";

type AboutImageMedia = Extract<
	NonNullable<CollectionEntry<"about">["data"]["section"]>["media"],
	{ type: "image" }
>;

const aboutEntries = (await getCollection("about")).sort((a, b) =>
	a.id.localeCompare(b.id),
);

const aboutSections = await Promise.all(
	aboutEntries.map(async (entry) => {
		const { Content } = await render(entry);
		const media = entry.data.section?.media;

		if (media && media.type !== "image") {
			throw new Error(
				`About entry ${entry.id} uses unsupported media type: ${media.type}`,
			);
		}

		return {
			id: entry.id,
			title: entry.data.title ?? entry.id,
			Content,
			media: media as AboutImageMedia | undefined,
		};
	}),
);
---

<DefaultLayout title="About">
	<h1>A little bit about me</h1>
	<article class="about-content">
		{
			aboutSections.map(({ id, title, Content, media }, index) => (
				<section
					class:list={[
						"about-section",
						media ? "about-section--has-media" : "about-section--copy-only",
						media && index % 2 === 1 ? "about-section--reverse" : undefined,
					]}
					data-about-section={id}>
					<div class="about-section-copy">
						<h2>{title}</h2>
						<Content />
					</div>
					{media ? (
						<div class="about-section-media">
							<AboutSectionMedia media={media} />
						</div>
					) : null}
				</section>
			))
		}
	</article>
	<div class="about-actions">
		<p class="about-actions-note">
			Thanks for reading all of this! (if you did)
		</p>
		<ImperfectButton
			href="/projects"
			fill="var(--color-home-button-yellow)">
			See my projects
		</ImperfectButton>
	</div>
</DefaultLayout>

<style>
	h1 {
		font-size: clamp(1.9rem, 5vw, 3.5rem);
		font-weight: 700;
		text-align: center;
		width: min(100%, 78rem);
		margin-inline: auto;
		margin-bottom: clamp(1.25rem, 3vw, 2rem);
	}

	.about-content {
		--text-measure: 65ch;
		--about-media-column-width: clamp(16rem, 28vw, 24rem);
		display: grid;
		gap: clamp(2.5rem, 5vw, 4.5rem);
		width: min(100%, 78rem);
		margin-inline: auto;
		margin-top: clamp(1rem, 3vw, 2rem);
	}

	.about-section {
		display: grid;
		gap: clamp(1.75rem, 4vw, 3.5rem);
		align-items: center;
	}

	.about-section--has-media {
		grid-template-columns: minmax(0, 1fr) var(--about-media-column-width);
		grid-template-areas: "copy media";
	}

	.about-section--has-media.about-section--reverse {
		grid-template-columns: var(--about-media-column-width) minmax(0, 1fr);
		grid-template-areas: "media copy";
	}

	.about-section--copy-only {
		grid-template-columns: minmax(0, 1fr);
	}

	.about-section-copy {
		min-width: 0;
		grid-area: copy;
	}

	.about-section-media {
		display: flex;
		justify-content: center;
		align-items: center;
		grid-area: media;
		width: 100%;
		min-width: 0;
	}

	h2 {
		font-family: var(--font-handwriting);
		font-size: clamp(1.5rem, 3vw, 2.5rem);
		font-weight: 700;
		letter-spacing: 0.01em;
		line-height: 1;
		margin: 0 0 1rem 0;
		max-width: 24ch;
	}

	.about-section-copy :global(p) {
		font-family: var(--font-sans);
		font-size: var(--type-sans-size-body);
		font-weight: var(--type-sans-weight-regular);
		color: var(--color-text-body);
		margin: 0 0 1rem 0;
		line-height: var(--type-sans-leading-reading);
		max-width: var(--text-measure);
		text-wrap: pretty;
	}

	.about-section-copy :global(ul) {
		padding-left: 1.25rem;
		margin: 0 0 1rem 0;
		list-style-type: disc;
	}

	.about-section-copy :global(li) {
		font-family: var(--font-sans);
		font-size: var(--type-sans-size-body);
		font-weight: var(--type-sans-weight-regular);
		color: var(--color-text-body);
		line-height: var(--type-sans-leading-compact);
		max-width: var(--text-measure);
		text-wrap: pretty;
	}

	.about-actions {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		width: min(100%, 78rem);
		margin: clamp(2rem, 5vw, 3.5rem) auto 0;
		text-align: center;
	}

	.about-actions-note {
		margin: 0;
		font-family: var(--font-handwriting);
		font-size: clamp(1.4rem, 2vw, 2rem);
		font-weight: 700;
		line-height: 1.1;
		text-wrap: balance;
	}

	@media (max-width: 760px) {
		.about-section--has-media,
		.about-section--has-media.about-section--reverse {
			grid-template-columns: 1fr;
			grid-template-areas:
				"copy"
				"media";
		}

		.about-section-media {
			justify-content: flex-start;
		}
	}
</style>
